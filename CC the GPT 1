    function getBitrate(quality) {
      return {
        low: 5e6,
        medium: 12e6,
        high: 25e6,
        ultra: 50e6
      }[quality] || 25e6;
    }

    function getMime(format) {
      const supported = (t) => MediaRecorder.isTypeSupported(t) ? t : null;

      if (format === "webm-vp9") {
        return supported("video/webm;codecs=vp9") || supported("video/webm") || "";
      }

      if (format === "webm") {
        return supported("video/webm") || "";
      }

      if (format === "mp4") {
        return supported("video/mp4;codecs=avc1") || supported("video/mp4") || "";
      }

      return supported("video/webm;codecs=vp9") || supported("video/webm") || "";
    }

    function getExt(mime) {
      return mime.includes("mp4") ? "mp4" : "webm";
    }

    function setRenderResolution(width, height) {
      renderer.setPixelRatio(1);
