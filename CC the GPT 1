<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Fractal Explorer, Psy Shader Mode Test</title>
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="mobile-web-app-capable" content="yes" />
  <style>
    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: black;
      font-family: Arial, sans-serif;
    }

    body {
      color: white;
    }

    #appShell {
      width: 100vw;
      height: 100vh;
      display: flex;
      position: relative;
      background: black;
    }

    #leftPanel {
      width: 240px;
      min-width: 240px;
      max-width: 240px;
      height: 100vh;
      overflow-y: auto;
      overflow-x: hidden;
      box-sizing: border-box;
      padding: 10px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      background: rgba(0, 0, 0, 0.72);
      backdrop-filter: blur(8px);
      border-right: 1px solid rgba(255, 255, 255, 0.12);
      z-index: 20;
    }

    #rightPanel {
      width: 340px;
      min-width: 340px;
      max-width: 340px;
      height: 100vh;
      overflow-y: auto;
      overflow-x: hidden;
      box-sizing: border-box;
      padding: 10px;
      background: rgba(0, 0, 0, 0.72);
      backdrop-filter: blur(8px);
      border-left: 1px solid rgba(255, 255, 255, 0.12);
      z-index: 20;
    }

    #canvasContainer {
      flex: 1;
      position: relative;
      min-width: 0;
      min-height: 0;
      overflow: hidden;
      background: black;
    }

    #previewFrame {
      position: absolute;
      background: black;
      overflow: hidden;
      box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08);
    }

    canvas {
      display: block;
      width: 100%;
      height: 100%;
    }

    .panelBox {
      background: rgba(255, 255, 255, 0.92);
      color: #000;
      padding: 10px;
      border: 1px solid #000;
      box-sizing: border-box;
    }

    .panelBox label {
      display: block;
      margin-bottom: 6px;
      font-size: 13px;
      font-weight: bold;
    }

    .rowGap {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    #leftPanel button,
    #leftPanel select,
    #leftPanel input {
      width: 100%;
      box-sizing: border-box;
      padding: 10px 12px;
      font-size: 14px;
      border: 1px solid #000;
    }

    #leftPanel button {
      background: #fff;
      color: #000;
      cursor: pointer;
      text-align: center;
    }

    #leftPanel button:disabled {
      opacity: 0.7;
      cursor: wait;
    }

    #leftPanel button.freezeBtn {
      background: #222;
      color: #fff;
      border-color: #555;
    }

    #leftPanel button.freezeBtn.active {
      background: #c00;
      color: #fff;
      border-color: #c00;
    }

    #startOverlay {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.78);
      backdrop-filter: blur(4px);
    }

    #startCard {
      width: min(92vw, 520px);
      padding: 34px 28px;
      border: 1px solid rgba(255, 255, 255, 0.24);
      background: rgba(0, 0, 0, 0.58);
      color: white;
      text-align: center;
      box-sizing: border-box;
    }

    #startCard h1 {
      margin: 0 0 10px 0;
      font-size: 38px;
      line-height: 1.1;
      letter-spacing: 0.02em;
      font-weight: 700;
    }

    #startCard p {
      margin: 0 0 22px 0;
      font-size: 15px;
      line-height: 1.5;
      color: rgba(255, 255, 255, 0.78);
    }

    .startButtons {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 10px;
    }

    .startButtons button {
      width: 100%;
      padding: 14px 16px;
      font-size: 16px;
      cursor: pointer;
      border: 1px solid white;
      background: white;
      color: black;
      box-sizing: border-box;
    }

    .startButtons button.secondary {
      background: transparent;
      color: white;
    }

    #startStatus {
      margin-top: 14px;
      min-height: 20px;
      font-size: 13px;
      color: rgba(255, 255, 255, 0.72);
    }

    .dg.main {
      width: 100% !important;
    }

    .dg {
      color: #fff !important;
    }

    .dg .cr.number input[type=text] {
      color: #000 !important;
    }

    #rightPanel .dg.main {
      margin: 0 !important;
    }

    @media only screen and (max-width: 1100px) {
      #leftPanel {
        width: 210px;
        min-width: 210px;
        max-width: 210px;
      }

      #rightPanel {
        width: 300px;
        min-width: 300px;
        max-width: 300px;
      }
    }

    @media only screen and (max-width: 900px) {
      #appShell {
        flex-direction: column;
      }

      #leftPanel,
      #rightPanel {
        width: 100%;
        min-width: 100%;
        max-width: 100%;
        height: auto;
        max-height: 28vh;
        border: none;
      }

      #leftPanel {
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
      }

      #rightPanel {
        border-top: 1px solid rgba(255, 255, 255, 0.12);
      }

      #canvasContainer {
        height: 44vh;
      }

      #startCard h1 {
        font-size: 32px;
      }
    }
  </style>
</head>
<body>
  <div id="startOverlay">
    <div id="startCard">
      <h1>Fractal Explorer</h1>
      <p>Choose how you want to start. You can use live microphone input for audio reactivity, or continue without it.</p>
      <div class="startButtons">
        <button id="enterWithMicBtn">Start with Microphone</button>
        <button id="enterWithoutMicBtn" class="secondary">Start without Microphone</button>
      </div>
      <div id="startStatus"></div>
    </div>
  </div>

  <div id="appShell">
    <div id="leftPanel">
      <div class="panelBox rowGap">
        <label for="presetNameInput">Preset Name</label>
        <input id="presetNameInput" type="text" placeholder="My preset" />

        <button id="savePresetBtn">Save Preset</button>
        <button id="overwritePresetBtn">Overwrite Selected</button>

        <label for="presetSelect">Load Preset</label>
        <select id="presetSelect">
          <option value="">No saved presets</option>
        </select>

        <button id="loadPresetBtn">Load Selected</button>
        <button id="deletePresetBtn">Delete Selected</button>
        <button id="exportPresetBtn">Export Preset JSON</button>
        <button id="importPresetBtn">Import Preset JSON</button>
        <input id="importPresetInput" type="file" accept=".json,application/json" style="display:none;" />
      </div>

      <div class="panelBox rowGap">
        <label for="exportFormatSelect">Export Format</label>
        <select id="exportFormatSelect">
          <option value="1280x720">Landscape HD, 1280 x 720</option>
          <option value="1920x1080">Landscape Full HD, 1920 x 1080</option>
          <option value="3840x2160" selected>Landscape 4K, 3840 x 2160</option>
          <option value="2160x3840">Vertical 4K, 2160 x 3840</option>
          <option value="1080x1920">Vertical HD, 1080 x 1920</option>
          <option value="2160x2160">Square 4K, 2160 x 2160</option>
        </select>

        <label for="formatSelect">Video Format</label>
        <select id="formatSelect">
          <option value="webm-vp9">WebM VP9</option>
          <option value="webm">WebM Basic</option>
          <option value="mp4">MP4, if supported</option>
        </select>

        <label for="qualitySelect">Video Quality</label>
        <select id="qualitySelect">
          <option value="low">Low, 5 Mbps</option>
          <option value="medium">Medium, 12 Mbps</option>
          <option value="high" selected>High, 25 Mbps</option>
          <option value="ultra">Ultra, 50 Mbps</option>
        </select>

        <label for="durationSelect">Clip Duration</label>
        <select id="durationSelect">
          <option value="5">5 sec</option>
          <option value="10" selected>10 sec</option>
          <option value="15">15 sec</option>
          <option value="30">30 sec</option>
        </select>
      </div>

      <button id="freezeBtn" class="freezeBtn">⏸ Freeze Animation</button>
      <button id="exportStillBtn">Export Still</button>
      <button id="recordBtn">Record Clip</button>
      <button id="fsToggleBtn">Enter Full Screen</button>
    </div>

    <div id="canvasContainer">
      <div id="previewFrame"></div>
    </div>

    <div id="rightPanel">
      <div id="gui"></div>
    </div>
  </div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/dat-gui/0.7.7/dat.gui.min.js"></script>

  <script id="fragmentShader" type="x-shader/x-fragment">
    #ifdef GL_OES_standard_derivatives
    #extension GL_OES_standard_derivatives : enable
    #endif

    precision mediump float;

    uniform vec2 iResolution;
    uniform float iTime;

    uniform float uPower;
    uniform float uBailout;
    uniform int uIterations;
    uniform float uSurfaceEpsilon;
    uniform int uMaxSteps;
    uniform float uMaxDistance;
    uniform vec3 uColor;

    uniform float uMusic;
    uniform int uShape;

    uniform vec3 uCamPos;
    uniform vec3 uCamRight;
    uniform vec3 uCamUp;
    uniform vec3 uCamForward;

    uniform vec3 uFractalRotation;

    uniform float uMirror;
    uniform float uMirrorQuad;

    uniform float uLightIntensity;
    uniform float uLightAzimuth;
    uniform float uLightElevation;
    uniform vec3 uLightColor;

    uniform float uShadowStrength;
    uniform vec3 uShadowTint;
    uniform float uContrast;
    uniform float uMidtoneLift;
    uniform float uSpecularStrength;
    uniform float uSpecularSize;

    uniform float uColorSaturation;
    uniform float uColorVibrance;
    uniform float uPaletteContrast;
    uniform float uColorIntensity;
    uniform float uPreserveHighlightColor;

    uniform float uRidgeAccent;
    uniform float uCavityStrength;

    uniform float uGlowOn;
    uniform vec3 uGlowColorA;
    uniform float uGlowAlphaA;
    uniform vec3 uGlowColorB;
    uniform float uGlowAlphaB;
    uniform float uGlowStrength;
    uniform float uGlowWidth;
    uniform float uGlowEmission;
    uniform float uGlowScroll;
    uniform float uGlowScrollSpeed;
    uniform float uGlowReverse;

    uniform float uLineOn;
    uniform vec3 uLineColorA;
    uniform float uLineAlphaA;
    uniform vec3 uLineColorB;
    uniform float uLineAlphaB;
    uniform float uLineStrength;
    uniform float uLineWidth;
    uniform float uLineSoftness;
    uniform float uLineScroll;
    uniform float uLineScrollSpeed;
    uniform float uLineReverse;

    uniform float uInnerGlowStrength;
    uniform float uInnerGlowWidth;
    uniform vec3 uInnerGlowColor;

    uniform float uPaletteMode;
    uniform float uRingScale;
    uniform float uRingStrength;
    uniform vec3 uWarmColor;
    uniform vec3 uCoolColor;
    uniform vec3 uPsyColorA;
    uniform vec3 uPsyColorB;
    uniform vec3 uPsyColorC;
    uniform vec3 uPsyColorD;
    uniform float uPsyMix;
    uniform float uPsyScale;
    uniform float uPsyFlow;
    uniform float uPsySpinStrength;
    uniform float uPaletteCycle;
    uniform float uPaletteCycleSpeed;
    uniform float uPsyStyle;

    uniform float uPatternMode;
    uniform float uPatternStrength;
    uniform float uPatternScale;
    uniform float uPatternSpeed;
    uniform float uPatternBlend;

    uniform float uColorBands;
    uniform float uBandStrength;

    uniform float uPsyShaderMode;
    uniform float uPsyEmission;
    uniform float uPsyDepthShade;
    uniform float uPsyContrast;
    uniform float uPsySaturation;
    uniform float uPsyInternalGlow;
    uniform float uPsyGlowThreshold;
    uniform float uPsyGlowOn;

    uniform float uSymmetryMode;
    uniform float uRadialSegments;
    uniform float uSymmetryStack;
    uniform float uTwistOn;
    uniform float uTwistAmount;
    uniform float uFoldOn;
    uniform float uFoldIterations;
    uniform float uTileOn;
    uniform float uTileAmount;
    uniform float uPolarOn;
    uniform float uOffsetOn;
    uniform float uOffsetAmount;

    uniform float uScreenRotateAngle;

    vec2 rotate2d(vec2 v, float a) {
      float c = cos(a);
      float s = sin(a);
      return vec2(v.x * c - v.y * s, v.x * s + v.y * c);
    }

    vec2 applyBaseMode(vec2 uv) {
      float m = uSymmetryMode;

      if (m < 0.5) {
        return uv;
      }

      if (m < 1.5) {
        uv.x = abs(uv.x);
        return uv;
      }

      if (m < 2.5) {
        uv.y = abs(uv.y);
        return uv;
      }

      if (m < 3.5) {
        return abs(uv);
      }

      if (m < 4.5) {
        vec2 t = (uv + 1.0) * 0.5;
        t = fract(t * 2.0);
        t = abs(t * 2.0 - 1.0);
        t = abs(t * 2.0 - 1.0);
        return t * 2.0 - 1.0;
      }

      if (m < 5.5) {
        vec2 t = (uv + 1.0) * 0.5;
        t = fract(t * 2.0);
        t = abs(t * 2.0 - 1.0);
        return t * 2.0 - 1.0;
      }

      if (m < 6.5) {
        if (uv.y > uv.x) {
          float tmp = uv.x;
          uv.x = uv.y;
          uv.y = tmp;
        }
        return uv;
      }

      if (m < 7.5) {
        float n = max(2.0, uRadialSegments);
        float slice = 3.14159265 / n;
        float angle = atan(uv.y, uv.x);
        float radius = length(uv);
        angle = mod(angle, 2.0 * slice);
        if (angle > slice) {
          angle = 2.0 * slice - angle;
        }
        return vec2(cos(angle), sin(angle)) * radius;
      }

      if (m < 8.5) {
        float s = max(0.1, uTileAmount);
        return (fract(uv * s + 0.5) - 0.5) / s;
      }

      if (m < 9.5) {
        float r = length(uv);
        float a = atan(uv.y, uv.x) / 3.14159265;
        return vec2(a, r - 0.5);
      }

      return uv;
    }

    vec2 applyTwist(vec2 uv) {
      return rotate2d(uv, length(uv) * uTwistAmount);
    }

    vec2 applyFold(vec2 uv) {
      int iters = int(clamp(uFoldIterations, 1.0, 5.0));
      for (int i = 0; i < 5; i++) {
        if (i >= iters) break;
        uv = abs(uv) - 0.5;
      }
      return uv;
    }

    vec2 applyTile(vec2 uv) {
      float s = max(0.1, uTileAmount);
      return (fract(uv * s + 0.5) - 0.5) / s;
    }

    vec2 applyPolar(vec2 uv) {
      float r = length(uv) + 0.0001;
      float a = atan(uv.y, uv.x);
      float nr = fract(r * 1.5 + 0.5) / 1.5;
      return vec2(cos(a + 0.4 / r), sin(a + 0.4 / r)) * nr;
    }

    vec2 applyOffset(vec2 uv) {
      float sector = floor(atan(uv.y, uv.x) / (3.14159265 / 4.0));
      float off = (fract(sector * 0.73 + 1.37) - 0.5) * uOffsetAmount;
      return rotate2d(uv, off);
    }

    vec2 applySymmetry(vec2 uv) {
      uv = applyBaseMode(uv);

      if (uSymmetryStack > 0.5) {
        if (uTwistOn > 0.5) {
          uv = applyTwist(uv);
        }
        if (uFoldOn > 0.5) {
          uv = applyFold(uv);
        }
        if (uTileOn > 0.5) {
          uv = applyTile(uv);
        }
        if (uPolarOn > 0.5) {
          uv = applyPolar(uv);
        }
        if (uOffsetOn > 0.5) {
          uv = applyOffset(uv);
        }
      }

      return uv;
    }

    mat3 rotationMatrix(vec3 angles) {
      float cx = cos(angles.x);
      float sx = sin(angles.x);
      float cy = cos(angles.y);
      float sy = sin(angles.y);
      float cz = cos(angles.z);
      float sz = sin(angles.z);

      mat3 rz = mat3(
        cz, -sz, 0.0,
        sz,  cz, 0.0,
        0.0, 0.0, 1.0
      );

      mat3 ry = mat3(
        cy, 0.0, sy,
        0.0, 1.0, 0.0,
        -sy, 0.0, cy
      );

      mat3 rx = mat3(
        1.0, 0.0, 0.0,
        0.0, cx, -sx,
        0.0, sx,  cx
      );

      return rz * ry * rx;
    }

    float mandelbulb(vec3 pos) {
      pos = rotationMatrix(uFractalRotation) * pos;

      vec3 z = pos;
      float dr = 1.0;
      float r = 0.0;

      for (int i = 0; i < 100; i++) {
        if (i >= uIterations) break;

        r = length(z);
        if (r > uBailout) break;

        if (uShape == 0) {
          float safeR = max(r, 0.00001);
          float theta = acos(z.z / safeR);
          float phi = atan(z.y, z.x);
          dr = pow(safeR, uPower - 1.0) * uPower * dr + 1.0;
          float zr = pow(safeR, uPower);
          theta *= uPower;
          phi *= uPower;
          z = zr * vec3(
            sin(theta) * cos(phi),
            sin(theta) * sin(phi),
            cos(theta)
          );
        } else if (uShape == 1) {
          float rc = max(max(abs(z.x), abs(z.y)), abs(z.z));
          float safeRc = max(rc, 0.00001);
          dr = pow(safeRc, uPower - 1.0) * uPower * dr + 1.0;
          z = sign(z) * pow(safeRc, uPower);
        } else if (uShape == 2) {
          float rp = max(abs(z.x) + abs(z.y), abs(z.z));
          float safeRp = max(rp, 0.00001);
          dr = pow(safeRp, uPower - 1.0) * uPower * dr + 1.0;
          z = sign(z) * pow(safeRp, uPower);
        } else {
          float rh = max(length(z.xy) / cos(3.14159 / 6.0), abs(z.z));
          float safeRh = max(rh, 0.00001);
          dr = pow(safeRh, uPower - 1.0) * uPower * dr + 1.0;
          z = sign(z) * pow(safeRh, uPower);
        }

        z += pos;
      }

      return 0.5 * log(max(r, 0.00001)) * r / max(dr, 0.00001);
    }

    float calcShadow(vec3 ro, vec3 rd) {
      float t = 0.01;
      float shadow = 1.0;

      for (int i = 0; i < 50; i++) {
        float d = mandelbulb(ro + rd * t);
        if (d < uSurfaceEpsilon) {
          shadow = 0.0;
          break;
        }
        t += d;
        if (t > uMaxDistance) break;
      }

      return shadow;
    }

    float rayMarch(vec3 ro, vec3 rd) {
      float t = 0.0;

      for (int i = 0; i < 300; i++) {
        if (i >= uMaxSteps) break;
        float d = mandelbulb(ro + rd * t);
        if (d < uSurfaceEpsilon) return t;
        t += d;
        if (t > uMaxDistance) break;
      }

      return t;
    }

    vec3 calcNormal(vec3 pos) {
      float eps = 0.001;
      return normalize(vec3(
        mandelbulb(pos + vec3(eps, 0.0, 0.0)) - mandelbulb(pos - vec3(eps, 0.0, 0.0)),
        mandelbulb(pos + vec3(0.0, eps, 0.0)) - mandelbulb(pos - vec3(0.0, eps, 0.0)),
        mandelbulb(pos + vec3(0.0, 0.0, eps)) - mandelbulb(pos - vec3(0.0, 0.0, eps))
      ));
    }

    float luma(vec3 c) {
      return dot(c, vec3(0.299, 0.587, 0.114));
    }

    vec3 applySaturationAndVibrance(vec3 c, float saturation, float vibrance) {
      float lum = luma(c);
      vec3 gray = vec3(lum);
      c = mix(gray, c, saturation);

      float mx = max(max(c.r, c.g), c.b);
      float mn = min(min(c.r, c.g), c.b);
      float sat = mx - mn;
      float vibAmount = (1.0 - sat) * vibrance;
      c = mix(vec3(luma(c)), c, 1.0 + vibAmount);

      return c;
    }

    float quantizeBands(float v) {
      if (uColorBands < 1.5) return v;

      float bands = max(1.0, uColorBands);
      float q = floor(v * bands) / bands;
      float strength = clamp(uBandStrength, 0.0, 1.0);

      return mix(v, q, strength);
    }

    vec3 psyPalette(float t) {
      t = fract(t);

      if (t < 0.333333) {
        return mix(uPsyColorA, uPsyColorB, t / 0.333333);
      } else if (t < 0.666666) {
        return mix(uPsyColorB, uPsyColorC, (t - 0.333333) / 0.333333);
      } else {
        return mix(uPsyColorC, uPsyColorD, (t - 0.666666) / 0.333334);
      }
    }

    float patternValue(vec3 pos, float cyclePhase) {
      float x = pos.x;
      float y = pos.y;
      float z = pos.z;
      float r = length(pos.xy);
      float r3 = length(pos);
      float a = atan(y, x);
      float s = uPatternScale;
      float t = cyclePhase * uPatternSpeed;

      if (uPatternMode < 0.5) {
        return 0.0;
      } else if (uPatternMode < 1.5) {
        return 0.5 + 0.5 * sin(y * s + t);
      } else if (uPatternMode < 2.5) {
        return 0.5 + 0.5 * sin(x * s + t);
      } else if (uPatternMode < 3.5) {
        return 0.5 + 0.5 * sin((x + y) * s + t);
      } else if (uPatternMode < 4.5) {
        return 0.5 + 0.5 * sin(y * s + sin(x * s * 0.75 + t) * 2.0 + t);
      } else if (uPatternMode < 5.5) {
        return 0.5 + 0.5 * sin(x * s + sin(y * s * 0.75 + t) * 2.0 + t);
      } else if (uPatternMode < 6.5) {
        return step(0.0, sin(x * s + t) * sin(y * s + t));
      } else if (uPatternMode < 7.5) {
        float wx = x + sin(y * s * 0.65 + t) * 0.6;
        float wy = y + sin(x * s * 0.65 - t) * 0.6;
        return step(0.0, sin(wx * s) * sin(wy * s));
      } else if (uPatternMode < 8.5) {
        float qx = x * 0.866025 + y * 0.5;
        float h1 = abs(fract(qx * s) - 0.5);
        float h2 = abs(fract(y * s) - 0.5);
        float h3 = abs(fract((qx - y * 0.5) * s) - 0.5);
        return 1.0 - smoothstep(0.18, 0.24, min(min(h1, h2), h3));
      } else if (uPatternMode < 9.5) {
        return 0.5 + 0.5 * sin(r3 * s + t);
      } else if (uPatternMode < 10.5) {
        return 0.5 + 0.5 * sin((r3 + z * 0.4) * s + t);
      } else if (uPatternMode < 11.5) {
        return 0.5 + 0.5 * (sin(x * s + t) * sin(y * s * 1.2 - t * 0.8));
      } else if (uPatternMode < 12.5) {
        return 0.5 + 0.5 * sin(r * s - t);
      } else if (uPatternMode < 13.5) {
        return 0.5 + 0.5 * sin(a * s + t);
      } else if (uPatternMode < 14.5) {
        return 0.5 + 0.5 * sin(r * s + a * 3.0 - t);
      } else if (uPatternMode < 15.5) {
        return 0.5 + 0.5 * sin(r * s + a * 6.0 - t);
      } else if (uPatternMode < 16.5) {
        vec2 p = pos.xy * s;
        vec2 ip = floor(p);
        vec2 fp = fract(p);
        float md = 10.0;

        for (int yy = -1; yy <= 1; yy++) {
          for (int xx = -1; xx <= 1; xx++) {
            vec2 g = vec2(float(xx), float(yy));
            vec2 o = 0.5 + 0.35 * sin(vec2(1.7, 2.9) * dot(ip + g, vec2(7.1, 5.3)) + t);
            vec2 r2 = g + o - fp;
            md = min(md, dot(r2, r2));
          }
        }

        return 1.0 - smoothstep(0.0, 0.4, sqrt(md));
      }

      return 0.5 + 0.5 * sin((x + y + z) * s + sin((x - y) * s * 0.7 + t) * 2.0 + t);
    }

    void main() {
      vec2 uv = (gl_FragCoord.xy / iResolution.xy) * 2.0 - 1.0;
      uv.x *= iResolution.x / iResolution.y;

      uv = rotate2d(uv, uScreenRotateAngle);
      uv = applySymmetry(uv);

      vec3 ro = uCamPos;
      vec3 rd = normalize(uv.x * uCamRight + uv.y * uCamUp + 1.5 * uCamForward);

      float tVal = rayMarch(ro, rd);
      vec3 col = vec3(0.0);

      if (tVal < uMaxDistance) {
        vec3 pos = ro + rd * tVal;
        vec3 normal = calcNormal(pos);

        vec3 lightDir = normalize(vec3(
          cos(uLightAzimuth) * cos(uLightElevation),
          sin(uLightAzimuth) * cos(uLightElevation),
          sin(uLightElevation)
        ));

        float diffuse = max(dot(normal, lightDir), 0.0);
        float shadow = calcShadow(pos + normal * uSurfaceEpsilon * 2.0, lightDir);
        vec3 viewDir = normalize(ro - pos);
        vec3 halfDir = normalize(lightDir + viewDir);

        float specularExp = mix(96.0, 6.0, clamp((uSpecularSize - 0.1) / 2.9, 0.0, 1.0));
        float spec = pow(max(dot(normal, halfDir), 0.0), specularExp);
        vec3 specular = uLightColor * spec * uSpecularStrength * shadow;

        float lightVal = 0.14 + 0.86 * diffuse * shadow;
        lightVal = mix(1.0, lightVal, uShadowStrength);
        lightVal = pow(clamp(lightVal, 0.0, 1.0), max(0.05, uContrast));
        lightVal = clamp(lightVal + lightVal * (1.0 - lightVal) * uMidtoneLift, 0.0, 1.0);

        float rim = clamp(1.0 - abs(dot(normal, viewDir)), 0.0, 1.0);
        float cyclePhase = uPaletteCycle > 0.5 ? iTime * uPaletteCycleSpeed : 0.0;
        float pattern = quantizeBands(patternValue(pos, cyclePhase));

        vec3 baseCol;

        if (uPaletteMode < 0.5) {
          baseCol = mix(uShadowTint, uColor, lightVal);
        } else if (uPaletteMode < 1.5) {
          float rings = 0.5 + 0.5 * sin(length(pos.xy) * uRingScale + pos.z * 1.5 + cyclePhase);
          rings = smoothstep(0.18, 0.82, rings);
          rings = quantizeBands(rings);

          vec3 warm = mix(uShadowTint, uWarmColor, lightVal);
          vec3 cool = uCoolColor * pow(rim, 2.0);
          vec3 ringMix = mix(warm, cool, rings * uRingStrength);

          float patternDrive = pattern * uPatternBlend * uPatternStrength;
          ringMix = mix(ringMix, mix(uWarmColor, uCoolColor, pattern), patternDrive * 0.9);

          baseCol = mix(uShadowTint, ringMix, clamp(lightVal + 0.18, 0.0, 1.0));
        } else {
          float radiusField = length(pos.xy) * uPsyScale;
          float angleField = atan(pos.y, pos.x) * uPsySpinStrength;
          float depthField = pos.z * 1.3;
          float flowField = cyclePhase + iTime * uPsyFlow;
          float ridgeField = rim * 5.0;

          float band1;
          float band2;
          float band3;

          if (uPsyStyle < 0.5) {
            band1 = 0.5 + 0.5 * sin(radiusField * 0.8 + angleField * 0.75 + flowField * 0.7);
            band2 = 0.5 + 0.5 * sin((pos.x - pos.y) * uPsyScale * 0.45 + depthField * 0.7 + flowField * 0.5);
            band3 = 0.5 + 0.5 * sin(length(pos) * uPsyScale * 0.42 - angleField * 0.35);
          } else if (uPsyStyle < 1.5) {
            band1 = 0.5 + 0.5 * sin(radiusField + angleField + depthField + flowField);
            band2 = 0.5 + 0.5 * sin((pos.x - pos.y) * uPsyScale * 0.65 - angleField * 0.75 + ridgeField + flowField * 0.7);
            band3 = 0.5 + 0.5 * sin(length(pos) * uPsyScale * 0.55 + angleField * 1.2 - pos.z * 1.2 - flowField * 0.45);
          } else {
            band1 = 0.5 + 0.5 * sin(radiusField * 1.15 + angleField * 1.25 + depthField + flowField * 1.2);
            band2 = 0.5 + 0.5 * sin((pos.x - pos.y) * uPsyScale * 0.9 - angleField * 1.1 + ridgeField * 1.2 + flowField);
            band3 = 0.5 + 0.5 * sin(length(pos) * uPsyScale * 0.72 + angleField * 1.6 - pos.z * 1.8 - flowField * 0.7);
          }

          band1 = quantizeBands(band1);
          band2 = quantizeBands(band2);
          band3 = quantizeBands(band3);

          float patternDrive = pattern * uPatternBlend * uPatternStrength;
          float paletteT = fract(
            band1 * 0.30 +
            band2 * 0.26 +
            band3 * 0.20 +
            rim * uPsyMix * 0.16 +
            lightVal * 0.10 +
            patternDrive * 0.55
          );

          paletteT = pow(clamp(paletteT, 0.0, 1.0), max(0.1, uPaletteContrast));
          paletteT = quantizeBands(paletteT);

          vec3 psycho = psyPalette(paletteT);
          vec3 psycho2 = psyPalette(quantizeBands(fract(paletteT + 0.22)));
          vec3 psycho3 = psyPalette(quantizeBands(fract(paletteT + 0.47)));

          vec3 layeredPsy = mix(psycho, psycho2, band2 * 0.65);
          layeredPsy = mix(layeredPsy, psycho3, band3 * 0.5);

          float rings = quantizeBands(0.5 + 0.5 * sin(length(pos.xy) * uRingScale + angleField * 0.6 + cyclePhase));
          vec3 warmLift = mix(vec3(0.0), uWarmColor, rings * 0.24 * uRingStrength);
          vec3 ridgeCool = uCoolColor * pow(rim, 1.8) * 0.35;

          layeredPsy *= mix(0.7, 1.3, lightVal);
          layeredPsy += warmLift + ridgeCool;
          layeredPsy = mix(layeredPsy, mix(uPsyColorA, uPsyColorD, pattern), patternDrive * 0.75);

          baseCol = mix(uShadowTint, layeredPsy, clamp(lightVal + 0.22, 0.0, 1.0));
        }

        baseCol += uLightColor * pow(rim, 2.2) * uRidgeAccent * 0.35;
        baseCol -= vec3(pow(1.0 - diffuse, 2.0) * (1.0 - shadow) * uCavityStrength * 0.35);
        baseCol = applySaturationAndVibrance(baseCol * uColorIntensity, uColorSaturation, uColorVibrance);

        vec3 shadedColor;
        bool isPsy = (uPaletteMode > 1.5);

        if (isPsy && uPsyShaderMode > 0.5) {
          vec3 psy = max(baseCol, vec3(0.0));
          psy *= mix(1.0, 0.35 + 0.65 * lightVal, clamp(uPsyDepthShade, 0.0, 1.0));
          psy = pow(max(psy, vec3(0.0)), vec3(1.0 / max(0.001, uPsyContrast)));
          psy = mix(vec3(dot(psy, vec3(0.299, 0.587, 0.114))), psy, uPsySaturation);

          float glowMask = smoothstep(uPsyGlowThreshold, 1.0, max(max(psy.r, psy.g), psy.b));
          vec3 emissiveCol = psy * uPsyEmission + psy * glowMask * uPsyInternalGlow * uPsyGlowOn;

          if (uPsyShaderMode < 1.5) {
            shadedColor = emissiveCol;
          } else {
            shadedColor = mix(emissiveCol, emissiveCol * mix(0.55, 1.0, lightVal), clamp(uPsyDepthShade, 0.0, 1.0));
          }

          specular = vec3(0.0);
        } else {
          if (uPreserveHighlightColor > 0.5) {
            shadedColor = baseCol * mix(vec3(0.25), uLightColor, lightVal);
          } else {
            shadedColor = mix(baseCol * 0.35, baseCol, lightVal) + uLightColor * spec * 0.25;
          }
        }

        float glowWidthExp = mix(3.5, 0.35, clamp(uGlowWidth / 4.0, 0.0, 1.0));
        float rimPow = pow(rim, glowWidthExp);
        float glowAA = fwidth(rimPow) * 1.75 + 0.0005;
        float glowMask = smoothstep(0.02 - glowAA, 0.02 + glowAA, rimPow) *
                         (1.0 - smoothstep(0.65 - glowAA, 0.65 + glowAA, rimPow));

        float glowCoord = rim;
        if (uGlowScroll > 0.5) {
          float dir = mix(1.0, -1.0, step(0.5, uGlowReverse));
          glowCoord = fract(rim + iTime * uGlowScrollSpeed * dir);
        }

        vec3 glowLayer = mix(uGlowColorA, uGlowColorB, glowCoord) *
                         glowMask *
                         mix(uGlowAlphaA, uGlowAlphaB, glowCoord) *
                         uGlowStrength *
                         uGlowOn *
                         (1.0 + uGlowEmission);

        float lineWidthExp = mix(7.5, 1.2, clamp(uLineWidth / 4.0, 0.0, 1.0));
        float lineRim = pow(rim, lineWidthExp);
        float lineAA = fwidth(lineRim) * (0.5 + uLineSoftness * 2.0) + 0.0003;
        float lineCenter = 0.18;
        float lineMask = smoothstep(lineCenter - lineAA, lineCenter, lineRim) -
                         smoothstep(lineCenter, lineCenter + lineAA, lineRim);
        lineMask = clamp(lineMask * 8.0, 0.0, 1.0);

        float lineCoord = rim;
        if (uLineScroll > 0.5) {
          float dir = mix(1.0, -1.0, step(0.5, uLineReverse));
          lineCoord = fract(rim + iTime * uLineScrollSpeed * dir);
        }

        float lineMixAmt = lineMask *
                           mix(uLineAlphaA, uLineAlphaB, lineCoord) *
                           uLineStrength *
                           uLineOn;

        float innerExp = mix(6.0, 1.0, clamp(uInnerGlowWidth / 4.0, 0.0, 1.0));
        float innerPow = pow(rim, innerExp);
        float innerAA = fwidth(innerPow) * 2.0 + 0.0005;
        float innerMask = smoothstep(0.0, innerAA + 0.0001, innerPow) *
                          (1.0 - smoothstep(0.82 - innerAA, 0.82 + innerAA, innerPow));
        vec3 innerGlow = uInnerGlowColor * innerMask * uInnerGlowStrength;

        col = shadedColor + specular + glowLayer + innerGlow;
        col = mix(col, mix(uLineColorA, uLineColorB, lineCoord), clamp(lineMixAmt, 0.0, 1.0));
      }

      col *= uLightIntensity;
      gl_FragColor = vec4(clamp(col, 0.0, 1.0), 1.0);
    }
