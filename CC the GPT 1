    async function exportStill(width, height) {
      const originalPixelRatio = renderer.getPixelRatio();
      const originalResolution = material.uniforms.iResolution.value.clone();

      setRenderResolution(width, height);
      renderer.render(scene, orthoCamera);

      renderer.domElement.toBlob((blob) => {
        if (!blob) {
          alert("Export failed.");
          restorePreviewResolution(originalPixelRatio, originalResolution);
          return;
        }

        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = `fractal-${width}x${height}.png`;
        a.click();
        URL.revokeObjectURL(url);

        restorePreviewResolution(originalPixelRatio, originalResolution);
      }, "image/png");
