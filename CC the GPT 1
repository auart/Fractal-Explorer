    async function recordVideo({ durationMs = 10000, videoBitsPerSecond = 25e6, mimeType, width, height }) {
      const originalPixelRatio = renderer.getPixelRatio();
      const originalResolution = material.uniforms.iResolution.value.clone();

      setRenderResolution(width, height);

      let recorder;
      const stream = renderer.domElement.captureStream(60);

      try {
        recorder = new MediaRecorder(stream, {
          mimeType,
          videoBitsPerSecond
        });
      } catch (err) {
        alert("Recording failed to start.");
        restorePreviewResolution(originalPixelRatio, originalResolution);
        return;
      }

      const chunks = [];
      const ext = getExt(mimeType);

      recorder.ondataavailable = (e) => {
        if (e.data && e.data.size > 0) {
          chunks.push(e.data);
        }
      };

      recorder.onstop = () => {
        const blob = new Blob(chunks, { type: mimeType });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");

        a.href = url;
        a.download = `fractal-clip-${width}x${height}.${ext}`;
        a.click();

        setTimeout(() => URL.revokeObjectURL(url), 1000);

        restorePreviewResolution(originalPixelRatio, originalResolution);
        recordBtn.disabled = false;
        recordBtn.textContent = "Record Clip";
      };

      recorder.start();
      recordBtn.disabled = true;
      recordBtn.textContent = "Recording...";

      setTimeout(() => {
        recorder.stop();
      }, durationMs);
    }

