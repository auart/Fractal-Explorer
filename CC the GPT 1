      try {
        const raw = localStorage.getItem(PRESET_STORAGE_KEY);
        return raw ? (JSON.parse(raw) || {}) : {};
      } catch (err) {
        return {};
      }
    }

    function savePresetsToStorage(presets) {
      localStorage.setItem(PRESET_STORAGE_KEY, JSON.stringify(presets));
    }

