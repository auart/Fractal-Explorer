      glowF.add(params, "glowStrength", 0, 2).name("Glow Strength");
      glowF.add(params, "glowWidth", 0.15, 4).name("Glow Width");
      glowF.add(params, "glowEmission", 0, 3).name("Glow Emission");
      glowF.add(params, "glowScroll").name("Glow Scroll");
      glowF.add(params, "glowScrollSpeed", 0, 3).name("Glow Scroll Speed");
      glowF.add(params, "glowReverse").name("Glow Reverse");

      const lineF = gui.addFolder("Edge Line");
      lineF.add(params, "lineOn").name("Line On");
      lineF.addColor(params, "lineColorA").name("Line Color A");
      lineF.add(params, "lineAlphaA", 0, 1).name("Line Alpha A");
      lineF.addColor(params, "lineColorB").name("Line Color B");
      lineF.add(params, "lineAlphaB", 0, 1).name("Line Alpha B");
      lineF.add(params, "lineStrength", 0, 2).name("Line Strength");
      lineF.add(params, "lineWidth", 0.1, 4).name("Line Width");
      lineF.add(params, "lineSoftness", 0, 1).name("Line Softness");
      lineF.add(params, "lineScroll").name("Line Scroll");
      lineF.add(params, "lineScrollSpeed", 0, 3).name("Line Scroll Speed");
      lineF.add(params, "lineReverse").name("Line Reverse");

      const igF = gui.addFolder("Inner Glow");
      igF.add(params, "innerGlowStrength", 0, 2).name("Inner Glow Strength");
      igF.add(params, "innerGlowWidth", 0.1, 4).name("Inner Glow Width");
      igF.addColor(params, "innerGlowColor").name("Inner Glow Color");

      const audioF = gui.addFolder("Audio Settings");
      audioF.add(params, "musicReact").name("Mic Reactive");
      audioF.add(params, "micSensitivity", 0, 5).name("Mic Sensitivity");
      audioF.add(params, "musicMatch").name("Music Match");

      const miscF = gui.addFolder("Misc");
      rotXController = miscF.add(params, "uFractalRotationX", 0, Math.PI * 2).name("Rotation X");
      rotYController = miscF.add(params, "uFractalRotationY", 0, Math.PI * 2).name("Rotation Y");
      rotZController = miscF.add(params, "uFractalRotationZ", 0, Math.PI * 2).name("Rotation Z");
      miscF.add(params, "mirror").name("Mirror Mode (legacy)");
      miscF.add(params, "mirrorQuad").name("Quad Mirror (legacy)");

      fractalF.open();
      colorF.open();
      psyF.open();
      gradF.open();
      patF.open();
      lightF.open();
      glowF.close();
      lineF.close();
      igF.close();
      audioF.close();
      miscF.close();

      window.addEventListener("resize", () => {
        layoutPreviewFrame();
        resizeRendererToPreviewFrame();
      });

      renderer.domElement.addEventListener("mousedown", onMouseDown);
      renderer.domElement.addEventListener("mouseup", onMouseUp);
      renderer.domElement.addEventListener("mousemove", onMouseMove);
      renderer.domElement.addEventListener("touchstart", onTouchStart, { passive: false });
      renderer.domElement.addEventListener("touchmove", onTouchMove, { passive: false });
      renderer.domElement.addEventListener("touchend", onTouchEnd);

      clock = new THREE.Clock();
      updateFreezeBtn();
    }

    const _fwd = new THREE.Vector3();
    const _rgt = new THREE.Vector3();
    const _up = new THREE.Vector3();

    function animate() {
      requestAnimationFrame(animate);

      const rawDelta = clock.getDelta();
      const rawElapsed = clock.elapsedTime;

      if (!isFrozen) {
        animationTime += rawDelta;
      } else {
        animationTime = frozenTime;
      }

      const dt = isFrozen ? 0.0 : rawDelta;
      const t = isFrozen ? frozenTime : animationTime;

      params.zoomValue = clampZoom(params.zoomValue);
      params.uBailout = safeBailout(params.uBailout);

      let sensitiveAvg = 0;

      if (params.musicReact && micEnabled) {
        analyser.getByteFrequencyData(dataArray);
        let sum = 0;
        for (let i = 0; i < bufferLength; i++) {
          sum += dataArray[i];
        }
        sensitiveAvg = (sum / bufferLength / 255.0) * params.micSensitivity;
      }

      if (params.trippyMode) {
        const hue = (t * (params.trippySpeed / 10.0)) % 1.0;
        material.uniforms.uColor.value.setHSL(hue, 0.7, 0.5);
      } else {
        material.uniforms.uColor.value.set(params.uColor);
      }

      if (params.kaleidoscopeMode) {
        params.lightAzimuth = ((params.lightAzimuth + dt * params.kaleidoscopeSpeed + Math.PI) % (Math.PI * 2)) - Math.PI;
        if (lightAzimuthController) {
          lightAzimuthController.updateDisplay();
        }
      }

      if (params.powerAnimation) {
        let speed = params.powerAnimationSpeed;

        if (params.musicMatch && micEnabled) {
          if (sensitiveAvg > 0.4 && (t - lastBeatTime > 0.3)) {
            bpm = 60.0 / Math.max(0.0001, (t - lastBeatTime));
            lastBeatTime = t;
          }
          speed *= bpm / 120.0;
        }

        const range = params.powerMax - params.powerMin;

        if (range <= 0.0001) {
          material.uniforms.uPower.value = params.powerMin;
        } else {
          const x = (t * speed) % (2.0 * range);
          material.uniforms.uPower.value = params.powerMin + (x < range ? x : (2.0 * range - x));
        }
      } else {
        material.uniforms.uPower.value = params.uPower;
      }

      if (!isDragging) {
        if (params.autoRotateX) params.uFractalRotationX += dt * params.rotateSpeedX;
        if (params.autoRotateY) params.uFractalRotationY += dt * params.rotateSpeedY;
        if (params.autoRotateZ) params.uFractalRotationZ += dt * params.rotateSpeedZ;
      }

      if (rotXController) rotXController.updateDisplay();
      if (rotYController) rotYController.updateDisplay();
      if (rotZController) rotZController.updateDisplay();

      let effectiveZoom = params.zoomValue;

      if (params.breathingOn) {
        const breathOffset = Math.sin(t * params.breathingSpeed) * params.breathingAmount;
        effectiveZoom = clampZoom(params.zoomValue + breathOffset);
      }

      navCamera.position.set(0, 0, effectiveZoom);
      navCamera.quaternion.set(0, 0, 0, 1);

      let screenRotateAngle = 0.0;
      if (params.cameraRotateOn) {
        screenRotateAngle = t * params.cameraRotateSpeed;
      }

      if (params.psyScaleCycle) {
        const animatedScale = params.psyScale + Math.sin(t * params.psyScaleCycleSpeed) * params.psyScaleCycleAmount;
        material.uniforms.uPsyScale.value = Math.max(0.1, animatedScale);
      } else {
        material.uniforms.uPsyScale.value = params.psyScale;
      }

      material.uniforms.iTime.value = t;
      material.uniforms.uMusic.value = (params.musicReact && micEnabled) ? sensitiveAvg : 0.0;
      material.uniforms.uFractalRotation.value.set(
        params.uFractalRotationX,
        params.uFractalRotationY,
        params.uFractalRotationZ
      );

      material.uniforms.uBailout.value = safeBailout(params.uBailout);
      material.uniforms.uIterations.value = params.uIterations;
      material.uniforms.uSurfaceEpsilon.value = params.uSurfaceEpsilon;
      material.uniforms.uMaxSteps.value = FIXED_MAX_STEPS;
      material.uniforms.uMaxDistance.value = FIXED_MAX_DISTANCE;
      material.uniforms.uShape.value = params.uShape;
      material.uniforms.uMirror.value = params.mirror ? 1.0 : 0.0;
      material.uniforms.uMirrorQuad.value = params.mirrorQuad ? 1.0 : 0.0;

      material.uniforms.uLightIntensity.value = params.lightIntensity;
      material.uniforms.uLightAzimuth.value = params.lightAzimuth;
      material.uniforms.uLightElevation.value = params.lightElevation;
      material.uniforms.uLightColor.value.set(params.lightColor);
      material.uniforms.uShadowStrength.value = params.shadowStrength;
      material.uniforms.uShadowTint.value.set(params.shadowTint);
      material.uniforms.uContrast.value = params.contrast;
      material.uniforms.uMidtoneLift.value = params.midtoneLift;
      material.uniforms.uSpecularStrength.value = params.specularStrength;
      material.uniforms.uSpecularSize.value = params.specularSize;

      material.uniforms.uColorSaturation.value = params.colorSaturation;
      material.uniforms.uColorVibrance.value = params.colorVibrance;
      material.uniforms.uPaletteContrast.value = params.paletteContrast;
      material.uniforms.uColorIntensity.value = params.colorIntensity;
      material.uniforms.uPreserveHighlightColor.value = params.preserveHighlightColor ? 1.0 : 0.0;
      material.uniforms.uRidgeAccent.value = params.ridgeAccent;
      material.uniforms.uCavityStrength.value = params.cavityStrength;

      material.uniforms.uGlowOn.value = params.glowOn ? 1.0 : 0.0;
      material.uniforms.uGlowColorA.value.set(params.glowColorA);
      material.uniforms.uGlowAlphaA.value = params.glowAlphaA;
      material.uniforms.uGlowColorB.value.set(params.glowColorB);
      material.uniforms.uGlowAlphaB.value = params.glowAlphaB;
      material.uniforms.uGlowStrength.value = params.glowStrength;
      material.uniforms.uGlowWidth.value = params.glowWidth;
      material.uniforms.uGlowEmission.value = params.glowEmission;
      material.uniforms.uGlowScroll.value = params.glowScroll ? 1.0 : 0.0;
      material.uniforms.uGlowScrollSpeed.value = params.glowScrollSpeed;
      material.uniforms.uGlowReverse.value = params.glowReverse ? 1.0 : 0.0;

      material.uniforms.uLineOn.value = params.lineOn ? 1.0 : 0.0;
      material.uniforms.uLineColorA.value.set(params.lineColorA);
      material.uniforms.uLineAlphaA.value = params.lineAlphaA;
      material.uniforms.uLineColorB.value.set(params.lineColorB);
      material.uniforms.uLineAlphaB.value = params.lineAlphaB;
      material.uniforms.uLineStrength.value = params.lineStrength;
      material.uniforms.uLineWidth.value = params.lineWidth;
      material.uniforms.uLineSoftness.value = params.lineSoftness;
      material.uniforms.uLineScroll.value = params.lineScroll ? 1.0 : 0.0;
      material.uniforms.uLineScrollSpeed.value = params.lineScrollSpeed;
      material.uniforms.uLineReverse.value = params.lineReverse ? 1.0 : 0.0;

      material.uniforms.uInnerGlowStrength.value = params.innerGlowStrength;
      material.uniforms.uInnerGlowWidth.value = params.innerGlowWidth;
      material.uniforms.uInnerGlowColor.value.set(params.innerGlowColor);

      material.uniforms.uPaletteMode.value = params.paletteMode;
      material.uniforms.uRingScale.value = params.ringScale;
      material.uniforms.uRingStrength.value = params.ringStrength;
      material.uniforms.uWarmColor.value.set(params.warmColor);
      material.uniforms.uCoolColor.value.set(params.coolColor);
      material.uniforms.uPsyColorA.value.set(params.psyColorA);
      material.uniforms.uPsyColorB.value.set(params.psyColorB);
      material.uniforms.uPsyColorC.value.set(params.psyColorC);
      material.uniforms.uPsyColorD.value.set(params.psyColorD);
      material.uniforms.uPsyMix.value = params.psyMix;
      material.uniforms.uPsyFlow.value = params.psyFlow;
      material.uniforms.uPsySpinStrength.value = params.psySpinStrength;
      material.uniforms.uPaletteCycle.value = params.paletteCycle ? 1.0 : 0.0;
      material.uniforms.uPaletteCycleSpeed.value = params.paletteCycleSpeed;
      material.uniforms.uPsyStyle.value = params.psyStyle;

      material.uniforms.uPatternMode.value = params.patternMode;
      material.uniforms.uPatternStrength.value = params.patternStrength;
      material.uniforms.uPatternScale.value = params.patternScale;
      material.uniforms.uPatternSpeed.value = params.patternSpeed;
      material.uniforms.uPatternBlend.value = params.patternBlend;
      material.uniforms.uColorBands.value = params.colorBands;
      material.uniforms.uBandStrength.value = params.bandStrength;

      material.uniforms.uPsyShaderMode.value = params.psyShaderMode;
      material.uniforms.uPsyEmission.value = params.psyEmission;
      material.uniforms.uPsyDepthShade.value = params.psyDepthShade;
      material.uniforms.uPsyContrast.value = params.psyContrast;
      material.uniforms.uPsySaturation.value = params.psySaturation;
      material.uniforms.uPsyInternalGlow.value = params.psyInternalGlow;
      material.uniforms.uPsyGlowThreshold.value = params.psyGlowThreshold;
      material.uniforms.uPsyGlowOn.value = params.psyGlowOn ? 1.0 : 0.0;

      material.uniforms.uSymmetryMode.value = params.symmetryMode;
      material.uniforms.uRadialSegments.value = params.radialSegments;
      material.uniforms.uSymmetryStack.value = params.symmetryStack ? 1.0 : 0.0;
      material.uniforms.uTwistOn.value = params.twistOn ? 1.0 : 0.0;
      material.uniforms.uTwistAmount.value = params.twistAmount;
      material.uniforms.uFoldOn.value = params.foldOn ? 1.0 : 0.0;
      material.uniforms.uFoldIterations.value = params.foldIterations;
      material.uniforms.uTileOn.value = params.tileOn ? 1.0 : 0.0;
      material.uniforms.uTileAmount.value = params.tileAmount;
      material.uniforms.uPolarOn.value = params.polarOn ? 1.0 : 0.0;
      material.uniforms.uOffsetOn.value = params.offsetOn ? 1.0 : 0.0;
      material.uniforms.uOffsetAmount.value = params.offsetAmount;

      material.uniforms.uScreenRotateAngle.value = screenRotateAngle;

      material.uniforms.uCamPos.value.copy(navCamera.position);

      _fwd.set(0, 0, -1).applyQuaternion(navCamera.quaternion).normalize();
      _rgt.set(1, 0, 0).applyQuaternion(navCamera.quaternion).normalize();
      _up.set(0, 1, 0).applyQuaternion(navCamera.quaternion).normalize();

      material.uniforms.uCamForward.value.copy(_fwd);
      material.uniforms.uCamRight.value.copy(_rgt);
      material.uniforms.uCamUp.value.copy(_up);

      if (keys["ArrowUp"] || keys["w"]) navCamera.translateZ(-params.flySpeed);
      if (keys["ArrowDown"] || keys["s"]) navCamera.translateZ(params.flySpeed);
      if (keys["ArrowLeft"] || keys["a"]) navCamera.translateX(-params.flySpeed);
      if (keys["ArrowRight"] || keys["d"]) navCamera.translateX(params.flySpeed);
      if (keys["q"]) navCamera.translateY(params.flySpeed);
      if (keys["e"]) navCamera.translateY(-params.flySpeed);

      navCamera.position.z = Math.max(MIN_ZOOM, navCamera.position.z);

      if (!params.breathingOn) {
        params.zoomValue = clampZoom(navCamera.position.z);
      }

      renderer.render(scene, orthoCamera);
    }

    refreshPresetSelect();
    init();
    animate();
  </script>
</body>
</html>
