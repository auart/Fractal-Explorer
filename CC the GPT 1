      const presets = loadPresetsFromStorage();
      delete presets[selected];
      savePresetsToStorage(presets);
      refreshPresetSelect();
      presetNameInput.value = "";
    }

    function exportSelectedPreset() {
      const selected = presetSelect.value || presetNameInput.value.trim();

      if (!selected) {
        alert("Select or enter a preset name first.");
        return;
