<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Fractal Explorer – Safe GUI Build</title>
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="mobile-web-app-capable" content="yes">
  <style>
    html, body {
      margin: 0;
      padding: 0;
      overflow: hidden;
      width: 100%;
      height: 100%;
      background: black;
      font-family: Arial, sans-serif;
    }

    canvas {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      z-index: 0;
    }

    #gui {
      position: fixed;
      top: 10px;
      right: 10px;
      z-index: 10;
      max-height: calc(100vh - 20px);
      overflow-y: auto;
      overflow-x: hidden;
      width: 320px;
      box-sizing: border-box;
      padding-right: 4px;
    }

    #gui::-webkit-scrollbar {
      width: 10px;
    }

    #gui::-webkit-scrollbar-track {
      background: rgba(255,255,255,0.08);
    }

    #gui::-webkit-scrollbar-thumb {
      background: rgba(255,255,255,0.4);
    }

    #startBtn {
      position: fixed;
      top: 10px;
      left: 10px;
      z-index: 30;
      padding: 10px 20px;
      font-size: 16px;
    }

    #exportStillBtn,
    #recordBtn,
    #fsToggleBtn {
      position: fixed;
      left: 10px;
      z-index: 20;
      padding: 10px 20px;
      font-size: 16px;
      background: #fff;
      color: #000;
      border: 1px solid #000;
      cursor: pointer;
      width: 220px;
      box-sizing: border-box;
      text-align: center;
    }

    #exportStillBtn {
      bottom: 10px;
    }

    #fsToggleBtn {
      bottom: 60px;
    }

    #recordBtn {
      bottom: 110px;
    }

    #recordBtn:disabled {
      opacity: 0.7;
      cursor: wait;
    }

    #recordOptions {
      position: fixed;
      left: 10px;
      bottom: 160px;
      z-index: 25;
      background: rgba(255,255,255,0.92);
      color: #000;
      padding: 10px;
      border: 1px solid #000;
      font-size: 13px;
      width: 220px;
      box-sizing: border-box;
    }

    #recordOptions label {
      display: block;
      margin-bottom: 8px;
      font-weight: bold;
    }

    #recordOptions select {
      width: 100%;
      margin-top: 4px;
      padding: 4px;
      font-size: 13px;
      box-sizing: border-box;
    }

    @media only screen and (max-width: 768px) {
      #gui {
        width: 92vw;
      }

      #recordOptions,
      #exportStillBtn,
      #recordBtn,
      #fsToggleBtn {
        width: 220px;
      }
    }
  </style>
</head>
<body>
  <button id="startBtn">Enable Microphone</button>
  <button id="exportStillBtn">Export HD Still</button>
  <button id="fsToggleBtn">Enter Full Screen</button>
  <button id="recordBtn">Record Clip</button>

  <div id="recordOptions">
    <label>
      Format
      <select id="formatSelect">
        <option value="webm-vp9">WebM VP9</option>
        <option value="webm">WebM Basic</option>
        <option value="mp4">MP4, if supported</option>
      </select>
    </label>

    <label>
      Quality
      <select id="qualitySelect">
        <option value="low">Low, 5 Mbps</option>
        <option value="medium">Medium, 12 Mbps</option>
        <option value="high" selected>High, 25 Mbps</option>
        <option value="ultra">Ultra, 50 Mbps</option>
      </select>
    </label>

    <label>
      Duration
      <select id="durationSelect">
        <option value="5">5 sec</option>
        <option value="10" selected>10 sec</option>
        <option value="15">15 sec</option>
        <option value="30">30 sec</option>
      </select>
    </label>
  </div>

  <div id="gui"></div>

  <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/dat-gui/0.7.7/dat.gui.min.js"></script>

  <script id="fragmentShader" type="x-shader/x-fragment">
    precision mediump float;

    uniform vec2 iResolution;
    uniform float iTime;

    uniform float uPower;
    uniform float uBailout;
    uniform int uIterations;
    uniform float uSurfaceEpsilon;
    uniform int uMaxSteps;
    uniform float uMaxDistance;
    uniform vec3 uColor;
    uniform float uRainbow;
    uniform float uPulse;

    uniform float uMusic;
    uniform int uShape;

    uniform vec3 uCamPos;
    uniform vec3 uCamRight;
    uniform vec3 uCamUp;
    uniform vec3 uCamForward;

    uniform vec3 uFractalRotation;

    uniform float uMirror;
    uniform float uMirrorQuad;

    uniform float uLightIntensity;
    uniform float uLightAngle;

    mat3 rotationMatrix(vec3 angles) {
      float cx = cos(angles.x), sx = sin(angles.x);
      float cy = cos(angles.y), sy = sin(angles.y);
      float cz = cos(angles.z), sz = sin(angles.z);

      mat3 rx = mat3(
        1.0, 0.0, 0.0,
        0.0, cx, -sx,
        0.0, sx, cx
      );

      mat3 ry = mat3(
        cy, 0.0, sy,
        0.0, 1.0, 0.0,
        -sy, 0.0, cy
      );

      mat3 rz = mat3(
        cz, -sz, 0.0,
        sz, cz, 0.0,
        0.0, 0.0, 1.0
      );

      return rz * ry * rx;
    }

    float mandelbulb(vec3 pos) {
      pos = rotationMatrix(uFractalRotation) * pos;
      vec3 z = pos;
      float dr = 1.0;
      float r = 0.0;

      for (int i = 0; i < 100; i++) {
        if (i >= uIterations) break;
        r = length(z);
        if (r > uBailout) break;

        if (uShape == 0) {
          float theta = acos(z.z / r);
          float phi = atan(z.y, z.x);
          dr = pow(r, uPower - 1.0) * uPower * dr + 1.0;
          float zr = pow(r, uPower);
          theta *= uPower;
          phi *= uPower;
          z = zr * vec3(sin(theta) * cos(phi), sin(theta) * sin(phi), cos(theta));
        } else if (uShape == 1) {
          float rCube = max(max(abs(z.x), abs(z.y)), abs(z.z));
          dr = pow(rCube, uPower - 1.0) * uPower * dr + 1.0;
          float zr = pow(rCube, uPower);
          z = sign(z) * zr;
        } else if (uShape == 2) {
          float rPyr = max((abs(z.x) + abs(z.y)), abs(z.z));
          dr = pow(rPyr, uPower - 1.0) * uPower * dr + 1.0;
          float zr = pow(rPyr, uPower);
          z = sign(z) * zr;
        } else if (uShape == 3) {
          float rHexXY = length(vec2(z.x, z.y)) / cos(3.14159 / 6.0);
          float rHex = max(rHexXY, abs(z.z));
          dr = pow(rHex, uPower - 1.0) * uPower * dr + 1.0;
          float zr = pow(rHex, uPower);
          z = sign(z) * zr;
        }

        z += pos;
      }

      return 0.5 * log(r) * r / dr;
    }

    float calcShadow(vec3 ro, vec3 rd) {
      float t = 0.01;
      float shadow = 1.0;

      for (int i = 0; i < 50; i++) {
        float d = mandelbulb(ro + rd * t);
        if (d < uSurfaceEpsilon) {
          shadow = 0.0;
          break;
        }
        t += d;
        if (t > uMaxDistance) break;
      }

      return shadow;
    }

    float rayMarch(vec3 ro, vec3 rd) {
      float t = 0.0;

      for (int i = 0; i < 300; i++) {
        if (i >= uMaxSteps) break;
        vec3 pos = ro + rd * t;
        float d = mandelbulb(pos);
        if (d < uSurfaceEpsilon) return t;
        t += d;
        if (t > uMaxDistance) break;
      }

      return t;
    }

    vec3 calcNormal(vec3 pos) {
      float eps = 0.001;
      vec3 n;
      n.x = mandelbulb(pos + vec3(eps, 0.0, 0.0)) - mandelbulb(pos - vec3(eps, 0.0, 0.0));
      n.y = mandelbulb(pos + vec3(0.0, eps, 0.0)) - mandelbulb(pos - vec3(0.0, eps, 0.0));
      n.z = mandelbulb(pos + vec3(0.0, 0.0, eps)) - mandelbulb(pos - vec3(0.0, 0.0, eps));
      return normalize(n);
    }

    void main() {
      vec2 uv;
      vec2 baseUv = (gl_FragCoord.xy / iResolution.xy) * 2.0 - 1.0;
      baseUv.x *= iResolution.x / iResolution.y;

      if (uMirrorQuad > 0.5) {
        vec2 uv01 = (baseUv + 1.0) / 2.0;
        uv01 = mod(uv01 * 2.0, 1.0);
        uv01 = abs(uv01 - 0.5) * 2.0;
        uv = uv01 * 2.0 - 1.0;
      } else if (uMirror > 0.5) {
        uv = baseUv;
        uv.x = abs(uv.x);
      } else {
        uv = baseUv;
      }

      vec3 ro = uCamPos;
      vec3 rd = normalize(uv.x * uCamRight + uv.y * uCamUp + 1.5 * uCamForward);

      float tVal = rayMarch(ro, rd);
      vec3 col = vec3(0.0);

      if (tVal < uMaxDistance) {
        vec3 pos = ro + rd * tVal;
        vec3 normal = calcNormal(pos);
        vec3 lightDir = normalize(vec3(cos(uLightAngle), sin(uLightAngle), 1.0));
        float diffuse = max(dot(normal, lightDir), 0.0);
        float ambient = 0.2;
        float shadow = calcShadow(pos + normal * uSurfaceEpsilon * 2.0, lightDir);
        vec3 viewDir = normalize(ro - pos);
        vec3 halfDir = normalize(lightDir + viewDir);
        float spec = pow(max(dot(normal, halfDir), 0.0), 32.0);
        vec3 specular = vec3(1.0) * spec * 0.5;

        col = uColor * (ambient + (1.0 - ambient) * diffuse * shadow) + specular * shadow;

        if (uPulse > 0.5) {
          float pulse = 0.5 + 0.5 * sin(iTime * 2.0 + uMusic * 10.0);
          float tt = tVal / uMaxDistance;
          vec3 pulseColor = 0.5 + 0.5 * cos(6.28318 * (tt + iTime * 0.2 + vec3(0.0, 0.33, 0.66)));
          col *= mix(vec3(1.0), pulseColor, 0.3 * pulse * (0.5 + uMusic));
        } else if (uRainbow > 0.5) {
          float tt = tVal / uMaxDistance;
          vec3 rainbowColor = 0.5 + 0.5 * cos(6.28318 * (tt + iTime * 0.2 + vec3(0.0, 0.33, 0.66)));
          col = mix(col, rainbowColor, 0.5);
        }
      }

      col *= uLightIntensity;
      gl_FragColor = vec4(col, 1.0);
    }
  </script>

  <script>
    let navCamera, orthoCamera, scene, renderer, material, quad, clock;
    let gui;

    let params = {
      flySpeed: 0.05,
      uPower: 8.0,
      uBailout: 2.0,
      uIterations: 12,
      uSurfaceEpsilon: 0.001,
      uMaxSteps: 150,
      uMaxDistance: 200.0,
      uColor: "#FFD700",
      rainbow: false,
      pulse: true,
      uFractalRotationX: 0.0,
      uFractalRotationY: 0.0,
      uFractalRotationZ: 0.0,
      uShape: 0,
      musicReact: true,
      micSensitivity: 1.0,
      magicRotationSpeed: 5.0,
      mirror: false,
      mirrorQuad: false,
      lightIntensity: 1.0,
      lightAngle: 0.0,
      powerMin: 2.0,
      powerMax: 100.0,
      trippyMode: false,
      trippySpeed: 0.5,
      kaleidoscopeMode: false,
      kaleidoscopeSpeed: 1.0,
      musicMatch: false,
      zoomValue: 2.2
    };

    if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
      params.zoomValue = 3.8;
    }

    const magicRate = 1.5;
    let lastBeatTime = 0;
    let bpm = 120;
    let magicMode = false;
    let magicStartTime = 0;
    let magicEuler = new THREE.Euler(0, 0, 0);

    let rotXController, rotYController, rotZController, lightAngleController;
    let keys = {};

    window.addEventListener("keydown", (e) => {
      keys[e.key] = true;
    });

    window.addEventListener("keyup", (e) => {
      keys[e.key] = false;
    });

    let isDragging = false;
    let prevMouse = { x: 0, y: 0 };

    function onMouseDown(e) {
      isDragging = true;
      prevMouse.x = e.clientX;
      prevMouse.y = e.clientY;
    }

    function onMouseUp() {
      isDragging = false;
    }

    function onMouseMove(e) {
      if (isDragging) {
        let deltaX = e.clientX - prevMouse.x;
        let deltaY = e.clientY - prevMouse.y;

        params.uFractalRotationY += deltaX * 0.005;
        params.uFractalRotationX += deltaY * 0.005;

        if (rotXController) rotXController.updateDisplay();
        if (rotYController) rotYController.updateDisplay();
        if (rotZController) rotZController.updateDisplay();

        prevMouse.x = e.clientX;
        prevMouse.y = e.clientY;
      }
    }

    let isPinching = false;
    let lastPinchDist = 0;
    const zoomFactor = 0.005;

    function onTouchStart(e) {
      if (e.touches.length === 1) {
        isDragging = true;
        prevMouse.x = e.touches[0].clientX;
        prevMouse.y = e.touches[0].clientY;
      } else if (e.touches.length === 2) {
        isPinching = true;
        lastPinchDist = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY
        );
      }
    }

    function onTouchMove(e) {
      if (isPinching && e.touches.length === 2) {
        let currentDist = Math.hypot(
          e.touches[0].clientX - e.touches[1].clientX,
          e.touches[0].clientY - e.touches[1].clientY
        );

        let delta = currentDist - lastPinchDist;
        params.zoomValue += delta * zoomFactor;
        params.zoomValue = Math.max(0, Math.min(4, params.zoomValue));
        lastPinchDist = currentDist;
      } else if (isDragging && e.touches.length === 1) {
        let deltaX = e.touches[0].clientX - prevMouse.x;
        let deltaY = e.touches[0].clientY - prevMouse.y;

        params.uFractalRotationY += deltaX * 0.005;
        params.uFractalRotationX += deltaY * 0.005;

        if (rotXController) rotXController.updateDisplay();
        if (rotYController) rotYController.updateDisplay();
        if (rotZController) rotZController.updateDisplay();

        prevMouse.x = e.touches[0].clientX;
        prevMouse.y = e.touches[0].clientY;
      }

      e.preventDefault();
    }

    function onTouchEnd(e) {
      if (e.touches.length < 2) isPinching = false;
      if (e.touches.length === 0) isDragging = false;
    }

    const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
    const analyser = audioCtx.createAnalyser();
    analyser.fftSize = 256;

    const bufferLength = analyser.frequencyBinCount;
    const dataArray = new Uint8Array(bufferLength);

    window.onload = function () {
      alert("Please click 'Enable Microphone' to activate audio input.");
      setTimeout(() => {
        document.getElementById("startBtn").style.display = "none";
      }, 3000);
    };

    let micEnabled = false;

    document.getElementById("startBtn").addEventListener("click", () => {
      navigator.mediaDevices.getUserMedia({ audio: true }).then((stream) => {
        const micSource = audioCtx.createMediaStreamSource(stream);
        micSource.connect(analyser);
        micEnabled = true;
        document.getElementById("startBtn").style.display = "none";
      }).catch((err) => {
        console.error("Microphone access denied:", err);
      });
    });

    document.body.addEventListener("click", () => {
      if (!micEnabled) {
        navigator.mediaDevices.getUserMedia({ audio: true }).then((stream) => {
          const micSource = audioCtx.createMediaStreamSource(stream);
          micSource.connect(analyser);
          micEnabled = true;
          document.getElementById("startBtn").style.display = "none";
        }).catch((err) => {
          console.error("Microphone access denied:", err);
        });
      }
    });

    const fsToggleBtn = document.getElementById("fsToggleBtn");
    const exportStillBtn = document.getElementById("exportStillBtn");
    const recordBtn = document.getElementById("recordBtn");

    const formatSelect = document.getElementById("formatSelect");
    const qualitySelect = document.getElementById("qualitySelect");
    const durationSelect = document.getElementById("durationSelect");

    fsToggleBtn.addEventListener("click", () => {
      if (!document.fullscreenElement && !document.webkitFullscreenElement) {
        if (document.documentElement.requestFullscreen) {
          document.documentElement.requestFullscreen();
        } else if (document.documentElement.webkitRequestFullscreen) {
          document.documentElement.webkitRequestFullscreen();
        }
        fsToggleBtn.textContent = "Exit Full Screen";
      } else {
        if (document.exitFullscreen) {
          document.exitFullscreen();
        } else if (document.webkitExitFullscreen) {
          document.webkitExitFullscreen();
        }
        fsToggleBtn.textContent = "Enter Full Screen";
      }
    });

    exportStillBtn.addEventListener("click", async () => {
      await exportHDStill(3840, 2160);
    });

    function getBitrateFromQuality(quality) {
      switch (quality) {
        case "low": return 5000000;
        case "medium": return 12000000;
        case "high": return 25000000;
        case "ultra": return 50000000;
        default: return 25000000;
      }
    }

    function getMimeTypeFromFormat(format) {
      if (format === "webm-vp9") {
        if (MediaRecorder.isTypeSupported("video/webm;codecs=vp9")) return "video/webm;codecs=vp9";
        if (MediaRecorder.isTypeSupported("video/webm")) return "video/webm";
      }

      if (format === "webm") {
        if (MediaRecorder.isTypeSupported("video/webm")) return "video/webm";
      }

      if (format === "mp4") {
        if (MediaRecorder.isTypeSupported("video/mp4;codecs=avc1")) return "video/mp4;codecs=avc1";
        if (MediaRecorder.isTypeSupported("video/mp4")) return "video/mp4";
      }

      if (MediaRecorder.isTypeSupported("video/webm;codecs=vp9")) return "video/webm;codecs=vp9";
      if (MediaRecorder.isTypeSupported("video/webm")) return "video/webm";
      return "";
    }

    function getFileExtensionFromMimeType(mimeType) {
      if (mimeType.includes("mp4")) return "mp4";
      return "webm";
    }

    async function exportHDStill(width = 3840, height = 2160) {
      const originalSize = new THREE.Vector2();
      renderer.getSize(originalSize);

      const originalPixelRatio = renderer.getPixelRatio();
      const originalResolution = material.uniforms.iResolution.value.clone();

      try {
        renderer.setPixelRatio(1);
        renderer.setSize(width, height, false);
        material.uniforms.iResolution.value.set(width, height);

        renderer.render(scene, orthoCamera);

        renderer.domElement.toBlob((blob) => {
          if (!blob) {
            alert("Export failed.");
            return;
          }

          const link = document.createElement("a");
          const url = URL.createObjectURL(blob);
          link.href = url;
          link.download = `fractal-${width}x${height}.png`;
          link.click();
          URL.revokeObjectURL(url);
        }, "image/png");
      } finally {
        renderer.setPixelRatio(originalPixelRatio);
        renderer.setSize(originalSize.x, originalSize.y, false);
        material.uniforms.iResolution.value.copy(originalResolution);
        renderer.render(scene, orthoCamera);
      }
    }

    recordBtn.addEventListener("click", async () => {
      const durationMs = parseInt(durationSelect.value, 10) * 1000;
      const bitrate = getBitrateFromQuality(qualitySelect.value);
      const mimeType = getMimeTypeFromFormat(formatSelect.value);

      if (!mimeType) {
        alert("This browser does not support the selected recording format.");
        return;
      }

      await recordCanvasVideo(durationMs, bitrate, mimeType);
    });

    async function recordCanvasVideo(durationMs = 10000, videoBitsPerSecond = 25000000, mimeType = "video/webm;codecs=vp9") {
      const canvas = renderer.domElement;
      const stream = canvas.captureStream(60);

      let recorder;
      try {
        recorder = new MediaRecorder(stream, {
          mimeType,
          videoBitsPerSecond
        });
      } catch (err) {
        console.error("MediaRecorder setup failed:", err);
        alert("Recording failed to start with that format/settings.");
        return;
      }

      const chunks = [];
      const fileExt = getFileExtensionFromMimeType(mimeType);

      recorder.ondataavailable = (event) => {
        if (event.data && event.data.size > 0) {
          chunks.push(event.data);
        }
      };

      recorder.onstop = () => {
        const blob = new Blob(chunks, { type: mimeType });
        const url = URL.createObjectURL(blob);

        const link = document.createElement("a");
        link.href = url;
        link.download = `fractal-clip-${qualitySelect.value}.${fileExt}`;
        link.click();

        setTimeout(() => URL.revokeObjectURL(url), 1000);
      };

      recorder.start();

      recordBtn.disabled = true;
      recordBtn.textContent = "Recording...";

      setTimeout(() => {
        recorder.stop();
        recordBtn.disabled = false;
        recordBtn.textContent = "Record Clip";
      }, durationMs);
    }

    function init() {
      renderer = new THREE.WebGLRenderer({
        antialias: true,
        preserveDrawingBuffer: true
      });

      renderer.setSize(window.innerWidth, window.innerHeight);
      document.body.appendChild(renderer.domElement);

      navCamera = new THREE.PerspectiveCamera(
        75,
        window.innerWidth / window.innerHeight,
        0.1,
        1000
      );

      if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
        navCamera.position.set(0, 0, 3.8);
        params.zoomValue = 3.8;
      } else {
        navCamera.position.set(0, 0, 2.2);
        params.zoomValue = 2.2;
      }

      orthoCamera = new THREE.OrthographicCamera(-1, 1, 1, -1, 0, 1);
      scene = new THREE.Scene();

      let geometry = new THREE.PlaneGeometry(2, 2);
      let fs = document.getElementById("fragmentShader").textContent;

      material = new THREE.ShaderMaterial({
        fragmentShader: fs,
        uniforms: {
          iResolution: { value: new THREE.Vector2(window.innerWidth, window.innerHeight) },
          iTime: { value: 0 },
          uPower: { value: params.uPower },
          uBailout: { value: params.uBailout },
          uIterations: { value: params.uIterations },
          uSurfaceEpsilon: { value: params.uSurfaceEpsilon },
          uMaxSteps: { value: params.uMaxSteps },
          uMaxDistance: { value: params.uMaxDistance },
          uColor: { value: new THREE.Color(params.uColor) },
          uRainbow: { value: params.rainbow ? 1.0 : 0.0 },
          uPulse: { value: params.pulse ? 1.0 : 0.0 },
          uCamPos: { value: new THREE.Vector3() },
          uCamRight: { value: new THREE.Vector3() },
          uCamUp: { value: new THREE.Vector3() },
          uCamForward: { value: new THREE.Vector3() },
          uFractalRotation: { value: new THREE.Vector3(0, 0, 0) },
          uShape: { value: params.uShape },
          uMusic: { value: 0.0 },
          uRotationPivot: { value: new THREE.Vector3(0, 0, 0) },
          uMirrorQuad: { value: params.mirrorQuad ? 1.0 : 0.0 },
          uMirror: { value: params.mirror ? 1.0 : 0.0 },
          uLightIntensity: { value: params.lightIntensity },
          uLightAngle: { value: params.lightAngle }
        }
      });

      quad = new THREE.Mesh(geometry, material);
      scene.add(quad);

      gui = new dat.GUI({ autoPlace: false, width: 320 });
      document.getElementById("gui").appendChild(gui.domElement);

      const fractalFolder = gui.addFolder("Fractal Settings");
      fractalFolder.add(params, "uPower", 2.0, 100.0).name("Base Fractal Power");
      fractalFolder.add(params, "uBailout", 1.5, 4.0).name("Bailout");
      fractalFolder.add(params, "uIterations", 3, 20, 1).name("Iterations");
      fractalFolder.add(params, "uSurfaceEpsilon", 0.0001, 0.01).name("Surface Epsilon");
      fractalFolder.add(params, "uMaxSteps", 50, 300, 1).name("Max Steps");
      fractalFolder.add(params, "uMaxDistance", 50, 400).name("Max Distance");
      fractalFolder.add(params, "uShape", { Mandelbulb: 0, Cube: 1, Pyramid: 2, Hexagon: 3 }).name("Base Shape");

      const magicFolder = gui.addFolder("Magic Mode");
      magicFolder.add(params, "powerMin", 2, 100).name("Power Min").listen();
      magicFolder.add(params, "powerMax", 2, 100).name("Power Max").listen();
      magicFolder.add(params, "magicRotationSpeed", 0, 10).name("Magic Speed");
      magicFolder.add({
        magic: function () {
          magicMode = !magicMode;
          if (magicMode) {
            magicStartTime = clock.getElapsedTime();
            magicEuler.set(
              params.uFractalRotationX,
              params.uFractalRotationY,
              params.uFractalRotationZ
            );
          }
        }
      }, "magic").name("Magic");

      const colorFolder = gui.addFolder("Color & Effects");
      colorFolder.addColor(params, "uColor").name("Base Color");
      colorFolder.add(params, "rainbow").name("Rainbow Mode");
      colorFolder.add(params, "pulse").name("Pulse Mode");
      colorFolder.add(params, "trippyMode").name("Trippy Mode");
      colorFolder.add(params, "trippySpeed", 0, 1).name("Trippy Speed");

      const lightingFolder = gui.addFolder("Lighting");
      lightingFolder.add(params, "lightIntensity", 0, 2).name("Light Intensity");
      lightAngleController = lightingFolder.add(params, "lightAngle", 0, Math.PI * 2).name("Light Angle").listen();
      lightingFolder.add(params, "kaleidoscopeMode").name("Kaleidoscope Mode");
      lightingFolder.add(params, "kaleidoscopeSpeed", 0, 5).name("Kaleidoscope Speed");

      const audioFolder = gui.addFolder("Audio Settings");
      audioFolder.add(params, "musicReact").name("Mic Reactive");
      audioFolder.add(params, "micSensitivity", 0, 5).name("Mic Sensitivity");
      audioFolder.add(params, "musicMatch").name("Music Match");

      const miscFolder = gui.addFolder("Misc");
      miscFolder.add(params, "zoomValue", 0, 4).name("Zoom");
      rotXController = miscFolder.add(params, "uFractalRotationX", 0, Math.PI * 2).name("Rotation X");
      rotYController = miscFolder.add(params, "uFractalRotationY", 0, Math.PI * 2).name("Rotation Y");
      rotZController = miscFolder.add(params, "uFractalRotationZ", 0, Math.PI * 2).name("Rotation Z");
      miscFolder.add(params, "mirror").name("Mirror Mode");
      miscFolder.add(params, "mirrorQuad").name("Quad Mirror Mode");

      fractalFolder.open();
      lightingFolder.open();
      magicFolder.close();
      colorFolder.close();
      audioFolder.close();
      miscFolder.close();

      window.addEventListener("resize", onWindowResize, false);
      renderer.domElement.addEventListener("mousedown", onMouseDown, false);
      renderer.domElement.addEventListener("mouseup", onMouseUp, false);
      renderer.domElement.addEventListener("mousemove", onMouseMove, false);
      renderer.domElement.addEventListener("touchstart", onTouchStart, false);
      renderer.domElement.addEventListener("touchmove", onTouchMove, false);
      renderer.domElement.addEventListener("touchend", onTouchEnd, false);

      clock = new THREE.Clock();
    }

    function onWindowResize() {
      navCamera.aspect = window.innerWidth / window.innerHeight;
      navCamera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
      material.uniforms.iResolution.value.set(window.innerWidth, window.innerHeight);
    }

    function animate() {
      requestAnimationFrame(animate);

      const deltaTime = clock.getDelta();
      const elapsedTime = clock.elapsedTime;

      material.uniforms.iTime.value = elapsedTime;
      navCamera.position.z = params.zoomValue;

      let sensitiveAvg = 0;

      if (params.musicReact) {
        analyser.getByteFrequencyData(dataArray);
        let sum = 0;
        for (let i = 0; i < bufferLength; i++) {
          sum += dataArray[i];
        }
        let avg = sum / bufferLength / 255.0;
        sensitiveAvg = avg * params.micSensitivity;
      }

      if (params.trippyMode) {
        let effectiveTrippySpeed = params.trippySpeed * 5.0;
        let hue = (elapsedTime * effectiveTrippySpeed) % 1;
        let newColor = new THREE.Color().setHSL(hue, 0.7, 0.5);
        material.uniforms.uColor.value.copy(newColor);
      } else {
        material.uniforms.uColor.value.set(params.uColor);
      }

      if (params.kaleidoscopeMode) {
        params.lightAngle += deltaTime * params.kaleidoscopeSpeed;
        params.lightAngle = params.lightAngle % (Math.PI * 2);
        if (lightAngleController) lightAngleController.updateDisplay();
      }

      if (magicMode) {
        let tMagic = elapsedTime - magicStartTime;
        let range = params.powerMax - params.powerMin;
        let effectiveMagicSpeed, speedMultiplier;

        if (params.musicMatch) {
          let threshold = 0.4;
          if (sensitiveAvg > threshold && (elapsedTime - lastBeatTime > 0.3)) {
            let beatInterval = elapsedTime - lastBeatTime;
            lastBeatTime = elapsedTime;
            bpm = 60 / beatInterval;
          }
          effectiveMagicSpeed = (bpm / 120) * 5.0;
          speedMultiplier = effectiveMagicSpeed / 5.0;
        } else {
          effectiveMagicSpeed = params.magicRotationSpeed * (1 + sensitiveAvg * 5.0);
          speedMultiplier = effectiveMagicSpeed / 5.0;
        }

        let x = (tMagic * magicRate * speedMultiplier) % (2 * range);
        let newPower = (x < range)
          ? (params.powerMin + x)
          : (params.powerMin + (2 * range - x));

        material.uniforms.uPower.value = newPower;

        if (!isDragging) {
          magicEuler.x += deltaTime * speedMultiplier * 0.5;
          magicEuler.y += deltaTime * speedMultiplier * 1.0;
          magicEuler.z += deltaTime * speedMultiplier * 0.75;
          params.uFractalRotationX = magicEuler.x;
          params.uFractalRotationY = magicEuler.y;
          params.uFractalRotationZ = magicEuler.z;
        } else {
          magicEuler.set(
            params.uFractalRotationX,
            params.uFractalRotationY,
            params.uFractalRotationZ
          );
        }

        material.uniforms.uFractalRotation.value.set(
          params.uFractalRotationX,
          params.uFractalRotationY,
          params.uFractalRotationZ
        );

        if (rotXController) rotXController.updateDisplay();
        if (rotYController) rotYController.updateDisplay();
        if (rotZController) rotZController.updateDisplay();
      } else if (params.musicReact) {
        material.uniforms.uMusic.value = sensitiveAvg;
        material.uniforms.uPower.value = params.uPower;
        material.uniforms.uFractalRotation.value.set(
          params.uFractalRotationX,
          params.uFractalRotationY,
          params.uFractalRotationZ
        );
      } else {
        material.uniforms.uMusic.value = 0.0;
        material.uniforms.uPower.value = params.uPower;
        material.uniforms.uFractalRotation.value.set(
          params.uFractalRotationX,
          params.uFractalRotationY,
          params.uFractalRotationZ
        );
      }

      material.uniforms.uBailout.value = params.uBailout;
      material.uniforms.uIterations.value = params.uIterations;
      material.uniforms.uSurfaceEpsilon.value = params.uSurfaceEpsilon;
      material.uniforms.uMaxSteps.value = params.uMaxSteps;
      material.uniforms.uMaxDistance.value = params.uMaxDistance;
      material.uniforms.uRainbow.value = params.rainbow ? 1.0 : 0.0;
      material.uniforms.uPulse.value = params.pulse ? 1.0 : 0.0;
      material.uniforms.uShape.value = params.uShape;
      material.uniforms.uMirror.value = params.mirror ? 1.0 : 0.0;
      material.uniforms.uMirrorQuad.value = params.mirrorQuad ? 1.0 : 0.0;
      material.uniforms.uLightIntensity.value = params.lightIntensity;
      material.uniforms.uLightAngle.value = params.lightAngle;

      material.uniforms.uCamPos.value.copy(navCamera.position);

      let forward = new THREE.Vector3(0, 0, -1).applyQuaternion(navCamera.quaternion).normalize();
      let right = new THREE.Vector3(1, 0, 0).applyQuaternion(navCamera.quaternion).normalize();
      let up = new THREE.Vector3(0, 1, 0).applyQuaternion(navCamera.quaternion).normalize();

      material.uniforms.uCamForward.value.copy(forward);
      material.uniforms.uCamRight.value.copy(right);
      material.uniforms.uCamUp.value.copy(up);

      if (keys["ArrowUp"] || keys["w"]) navCamera.translateZ(-params.flySpeed);
      if (keys["ArrowDown"] || keys["s"]) navCamera.translateZ(params.flySpeed);
      if (keys["ArrowLeft"] || keys["a"]) navCamera.translateX(-params.flySpeed);
      if (keys["ArrowRight"] || keys["d"]) navCamera.translateX(params.flySpeed);
      if (keys["q"]) navCamera.translateY(params.flySpeed);
      if (keys["e"]) navCamera.translateY(-params.flySpeed);

      renderer.render(scene, orthoCamera);
    }

    init();
    animate();
  </script>
</body>
</html>
