  async function exportStill(width,height) {
    const origSize=new THREE.Vector2(); renderer.getSize(origSize);
    const origPR=renderer.getPixelRatio(), origRes=material.uniforms.iResolution.value.clone();
    try {
      renderer.setPixelRatio(1); renderer.setSize(width,height,false);
      material.uniforms.iResolution.value.set(width,height);
      renderer.render(scene,orthoCamera);
      renderer.domElement.toBlob(blob=>{
        if(!blob){alert("Export failed.");return;}
        const a=document.createElement("a"); a.href=URL.createObjectURL(blob); a.download=`fractal-${width}x${height}.png`; a.click();
      },"image/png");
    } finally {
      renderer.setPixelRatio(origPR); resizeRendererToPreviewFrame();
      material.uniforms.iResolution.value.copy(origRes); renderer.render(scene,orthoCamera);
    }
  }

