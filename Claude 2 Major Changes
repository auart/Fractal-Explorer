  async function recordCanvasVideo({durationMs=10000,videoBitsPerSecond=25e6,mimeType="video/webm;codecs=vp9",width,height}) {
    const origPR=renderer.getPixelRatio(), origRes=material.uniforms.iResolution.value.clone();
    try {
      renderer.setPixelRatio(1); renderer.setSize(width,height,false);
      material.uniforms.iResolution.value.set(width,height);
      renderer.render(scene,orthoCamera);
      const stream=renderer.domElement.captureStream(60);
      let rec; try { rec=new MediaRecorder(stream,{mimeType,videoBitsPerSecond}); }
      catch(err){alert("Recording failed.");return;}
      const chunks=[]; const ext=getFileExtFromMime(mimeType);
      rec.ondataavailable=e=>{if(e.data&&e.data.size>0)chunks.push(e.data);};
      rec.onstop=()=>{
        const b=new Blob(chunks,{type:mimeType}), url=URL.createObjectURL(b);
        const a=document.createElement("a"); a.href=url; a.download=`fractal-clip-${width}x${height}.${ext}`; a.click();
        setTimeout(()=>URL.revokeObjectURL(url),1000);
        renderer.setPixelRatio(origPR); resizeRendererToPreviewFrame();
        material.uniforms.iResolution.value.copy(origRes); renderer.render(scene,orthoCamera);
      };
      rec.start(); recordBtn.disabled=true; recordBtn.textContent="Recording...";
      setTimeout(()=>{ rec.stop(); recordBtn.disabled=false; recordBtn.textContent="Record Clip"; },durationMs);
    } catch(err) {
      console.error(err); renderer.setPixelRatio(origPR); resizeRendererToPreviewFrame();
      material.uniforms.iResolution.value.copy(origRes); renderer.render(scene,orthoCamera);
    }
  }

