<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Fractal Explorer</title>
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="mobile-web-app-capable" content="yes" />
  <style>
    html, body {
      margin: 0; padding: 0;
      width: 100%; height: 100%;
      overflow: hidden;
      background: black;
      font-family: Arial, sans-serif;
    }
    body { color: white; }

    #appShell {
      width: 100vw; height: 100vh;
      display: flex; position: relative;
      background: black;
    }

    /* Panel hide/show via class */
    #leftPanel {
      width: 240px; min-width: 240px; max-width: 240px;
      height: 100vh; overflow-y: auto; overflow-x: hidden;
      box-sizing: border-box; padding: 10px;
      display: flex; flex-direction: column; gap: 8px;
      background: rgba(0,0,0,0.72);
      backdrop-filter: blur(8px);
      border-right: 1px solid rgba(255,255,255,0.12);
      z-index: 20;
      transition: transform 0.22s ease, opacity 0.22s ease;
    }
    #rightPanel {
      width: 340px; min-width: 340px; max-width: 340px;
      height: 100vh; overflow-y: auto; overflow-x: hidden;
      box-sizing: border-box; padding: 10px;
      background: rgba(0,0,0,0.72);
      backdrop-filter: blur(8px);
      border-left: 1px solid rgba(255,255,255,0.12);
      z-index: 20;
      transition: transform 0.22s ease, opacity 0.22s ease;
    }
    #leftPanel.hidden  { transform: translateX(-100%); opacity: 0; pointer-events: none; }
    #rightPanel.hidden { transform: translateX(100%);  opacity: 0; pointer-events: none; }

    /* Panel toggle button — always visible in top-right of canvas area */
    #panelToggleBtn {
      position: absolute;
      top: 10px; right: 10px;
      z-index: 50;
      background: rgba(0,0,0,0.55);
      border: 1px solid rgba(255,255,255,0.28);
      color: white;
      font-size: 13px;
      padding: 6px 12px;
      cursor: pointer;
      backdrop-filter: blur(4px);
      user-select: none;
    }
    #panelToggleBtn:hover { background: rgba(255,255,255,0.12); }

    /* FPS counter */
    #fpsCounter {
      position: absolute;
      top: 10px; left: 10px;
      z-index: 50;
      background: rgba(0,0,0,0.50);
      border: 1px solid rgba(255,255,255,0.18);
      color: #0ff;
      font-size: 12px;
      font-family: monospace;
      padding: 4px 9px;
      pointer-events: none;
      backdrop-filter: blur(4px);
    }

    #canvasContainer {
      flex: 1; position: relative;
      min-width: 0; min-height: 0;
      overflow: hidden; background: black;
    }
    #previewFrame {
      position: absolute; background: black; overflow: hidden;
      box-shadow: 0 0 0 1px rgba(255,255,255,0.08);
    }
    canvas { display: block; width: 100%; height: 100%; }

    .panelBox {
      background: rgba(255,255,255,0.92);
      color: #000; padding: 10px;
      border: 1px solid #000; box-sizing: border-box;
    }
    .panelBox label {
      display: block; margin-bottom: 6px;
      font-size: 13px; font-weight: bold;
    }
    .rowGap { display: flex; flex-direction: column; gap: 6px; }

    #leftPanel button, #leftPanel select, #leftPanel input {
      width: 100%; box-sizing: border-box;
      padding: 10px 12px; font-size: 14px; border: 1px solid #000;
    }
    #leftPanel button {
      background: #fff; color: #000;
      cursor: pointer; text-align: center;
    }
    #leftPanel button:disabled { opacity: 0.7; cursor: wait; }
    #leftPanel button.accent {
      background: #1a1aff; color: #fff; border-color: #1a1aff;
    }
    #leftPanel button.accent:hover { background: #3333ff; }

    #startOverlay {
      position: fixed; inset: 0; z-index: 100;
      display: flex; align-items: center; justify-content: center;
      background: rgba(0,0,0,0.78); backdrop-filter: blur(4px);
    }
    #startCard {
      width: min(92vw, 520px); padding: 34px 28px;
      border: 1px solid rgba(255,255,255,0.24);
      background: rgba(0,0,0,0.58); color: white;
      text-align: center; box-sizing: border-box;
    }
    #startCard h1 {
      margin: 0 0 10px 0; font-size: 38px;
      line-height: 1.1; letter-spacing: 0.02em; font-weight: 700;
    }
    #startCard p {
      margin: 0 0 22px 0; font-size: 15px; line-height: 1.5;
      color: rgba(255,255,255,0.78);
    }
    .startButtons { display: flex; flex-direction: column; gap: 10px; margin-top: 10px; }
    .startButtons button {
      width: 100%; padding: 14px 16px; font-size: 16px;
      cursor: pointer; border: 1px solid white;
      background: white; color: black; box-sizing: border-box;
    }
    .startButtons button.secondary { background: transparent; color: white; }
    #startStatus {
      margin-top: 14px; min-height: 20px; font-size: 13px;
      color: rgba(255,255,255,0.72);
    }

    .dg.main { width: 100% !important; }
    .dg { color: #fff !important; }
    .dg .cr.number input[type=text] { color: #000 !important; }
    #rightPanel .dg.main { margin: 0 !important; }

    @media only screen and (max-width: 1100px) {
      #leftPanel  { width: 210px; min-width: 210px; max-width: 210px; }
      #rightPanel { width: 300px; min-width: 300px; max-width: 300px; }
    }
    @media only screen and (max-width: 900px) {
      #appShell { flex-direction: column; }
      #leftPanel, #rightPanel {
        width: 100%; min-width: 100%; max-width: 100%;
        height: auto; max-height: 28vh; border: none;
      }
      #leftPanel  { border-bottom: 1px solid rgba(255,255,255,0.12); }
      #rightPanel { border-top:    1px solid rgba(255,255,255,0.12); }
      #canvasContainer { height: 44vh; }
      #startCard h1 { font-size: 32px; }
    }
  </style>
</head>
<body>

<div id="startOverlay">
  <div id="startCard">
    <h1>Fractal Explorer</h1>
    <p>Choose how you want to start. You can use live microphone input for audio reactivity, or continue without it.</p>
    <div class="startButtons">
      <button id="enterWithMicBtn">Start with Microphone</button>
      <button id="enterWithoutMicBtn" class="secondary">Start without Microphone</button>
    </div>
    <div id="startStatus"></div>
  </div>
</div>

<div id="appShell">
  <div id="leftPanel">
    <div class="panelBox rowGap">
      <label for="presetNameInput">Preset Name</label>
      <input id="presetNameInput" type="text" placeholder="My preset" />
      <button id="savePresetBtn">Save Preset</button>
      <button id="overwritePresetBtn">Overwrite Selected</button>
      <label for="presetSelect">Load Preset</label>
      <select id="presetSelect"><option value="">No saved presets</option></select>
      <button id="loadPresetBtn">Load Selected</button>
      <button id="deletePresetBtn">Delete Selected</button>
      <button id="exportPresetBtn">Export Preset JSON</button>
      <button id="importPresetBtn">Import Preset JSON</button>
      <button id="randomPresetBtn" class="accent">🎲 Randomise Psy Preset</button>
      <input id="importPresetInput" type="file" accept=".json,application/json" style="display:none;" />
    </div>

    <div class="panelBox rowGap">
      <label for="exportFormatSelect">Export Format</label>
      <select id="exportFormatSelect">
        <option value="3840x2160" selected>Landscape 4K, 3840 x 2160</option>
        <option value="2160x3840">Vertical 4K, 2160 x 3840</option>
        <option value="1080x1920">Vertical HD, 1080 x 1920</option>
        <option value="2160x2160">Square 4K, 2160 x 2160</option>
      </select>
      <label for="formatSelect">Video Format</label>
      <select id="formatSelect">
        <option value="webm-vp9">WebM VP9</option>
        <option value="webm">WebM Basic</option>
        <option value="mp4">MP4, if supported</option>
      </select>
      <label for="qualitySelect">Video Quality</label>
      <select id="qualitySelect">
        <option value="low">Low, 5 Mbps</option>
        <option value="medium">Medium, 12 Mbps</option>
        <option value="high" selected>High, 25 Mbps</option>
        <option value="ultra">Ultra, 50 Mbps</option>
      </select>
      <label for="durationSelect">Clip Duration</label>
      <select id="durationSelect">
        <option value="5">5 sec</option>
        <option value="10" selected>10 sec</option>
        <option value="15">15 sec</option>
        <option value="30">30 sec</option>
      </select>
    </div>

    <button id="exportStillBtn">Export Still</button>
    <button id="recordBtn">Record Clip</button>
    <button id="fsToggleBtn">Enter Full Screen</button>
  </div>

  <div id="canvasContainer">
    <div id="previewFrame"></div>
    <button id="panelToggleBtn" title="Toggle panels  [H]">⊞ Panels</button>
    <div id="fpsCounter">-- fps</div>
  </div>

  <div id="rightPanel">
    <div id="gui"></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/dat-gui/0.7.7/dat.gui.min.js"></script>

<!-- =====================  FRAGMENT SHADER  ===================== -->
<script id="fragmentShader" type="x-shader/x-fragment">
#ifdef GL_OES_standard_derivatives
#extension GL_OES_standard_derivatives : enable
#endif

precision mediump float;

uniform vec2  iResolution;
uniform float iTime;

uniform float uPower;
uniform float uBailout;
uniform int   uIterations;
uniform float uSurfaceEpsilon;
uniform int   uMaxSteps;
uniform float uMaxDistance;
uniform vec3  uColor;
uniform float uMusic;
uniform int   uShape;

uniform vec3  uCamPos;
uniform vec3  uCamRight;
uniform vec3  uCamUp;
uniform vec3  uCamForward;
uniform vec3  uFractalRotation;

uniform float uMirror;
uniform float uMirrorQuad;

uniform float uLightIntensity;
uniform float uLightAzimuth;
uniform float uLightElevation;
uniform vec3  uLightColor;
uniform float uShadowStrength;
uniform vec3  uShadowTint;
uniform float uContrast;
uniform float uMidtoneLift;
uniform float uSpecularStrength;
uniform float uSpecularSize;

uniform float uColorSaturation;
uniform float uColorVibrance;
uniform float uPaletteContrast;
uniform float uColorIntensity;
uniform float uPreserveHighlightColor;
uniform float uRidgeAccent;
uniform float uCavityStrength;

uniform float uGlowOn;
uniform vec3  uGlowColorA;
uniform float uGlowAlphaA;
uniform vec3  uGlowColorB;
uniform float uGlowAlphaB;
uniform float uGlowStrength;
uniform float uGlowWidth;
uniform float uGlowEmission;
uniform float uGlowScroll;
uniform float uGlowScrollSpeed;
uniform float uGlowReverse;

uniform float uLineOn;
uniform vec3  uLineColorA;
uniform float uLineAlphaA;
uniform vec3  uLineColorB;
uniform float uLineAlphaB;
uniform float uLineStrength;
uniform float uLineWidth;
uniform float uLineSoftness;
uniform float uLineScroll;
uniform float uLineScrollSpeed;
uniform float uLineReverse;

uniform float uInnerGlowStrength;
uniform float uInnerGlowWidth;
uniform vec3  uInnerGlowColor;

uniform float uPaletteMode;
uniform float uRingScale;
uniform float uRingStrength;
uniform vec3  uWarmColor;
uniform vec3  uCoolColor;
uniform vec3  uPsyColorA;
uniform vec3  uPsyColorB;
uniform vec3  uPsyColorC;
uniform vec3  uPsyColorD;
uniform float uPsyMix;
uniform float uPsyScale;
uniform float uPsyFlow;
uniform float uPsySpinStrength;
uniform float uPaletteCycle;
uniform float uPaletteCycleSpeed;
uniform float uPsyStyle;

uniform float uPatternMode;
uniform float uPatternStrength;
uniform float uPatternScale;
uniform float uPatternSpeed;
uniform float uPatternBlend;

uniform float uColorBands;
uniform float uBandStrength;

uniform float uPsyShaderMode;
uniform float uPsyEmission;
uniform float uPsyDepthShade;
uniform float uPsyContrast;
uniform float uPsySaturation;
uniform float uPsyInternalGlow;
uniform float uPsyGlowThreshold;
uniform float uPsyGlowOn;

// ---- previously-added uniforms ----
uniform float uUseOutsideLight;
uniform float uFractalGlowAccumulation;
uniform float uPsyContrastBoost;
uniform float uPsyScaleCycle;
uniform float uPsyScaleCycleSpeed;
uniform float uEffectivePsyScale;

// ---- new uniforms v3 ----
uniform float uFogStrength;       // depth fog 0..1
uniform vec3  uFogColor;          // fog/background colour
uniform float uAOStrength;        // ambient occlusion 0..1
uniform float uSoftShadow;        // 0=hard, 1=soft penumbra
uniform float uHueRotateSpeed;    // HSV hue rotation speed
uniform float uChromaStrength;    // chromatic aberration strength

// =====================  helpers  =====================

mat3 rotationMatrix(vec3 angles) {
  float cx = cos(angles.x), sx = sin(angles.x);
  float cy = cos(angles.y), sy = sin(angles.y);
  float cz = cos(angles.z), sz = sin(angles.z);
  mat3 rx = mat3(1,0,0, 0,cx,-sx, 0,sx,cx);
  mat3 ry = mat3(cy,0,sy, 0,1,0, -sy,0,cy);
  mat3 rz = mat3(cz,-sz,0, sz,cz,0, 0,0,1);
  return rz * ry * rx;
}

float mandelbulb(vec3 pos) {
  pos = rotationMatrix(uFractalRotation) * pos;
  vec3 z = pos;
  float dr = 1.0, r = 0.0;
  for (int i = 0; i < 100; i++) {
    if (i >= uIterations) break;
    r = length(z);
    if (r > uBailout) break;
    if (uShape == 0) {
      float theta = acos(z.z / max(r, 1e-5));
      float phi   = atan(z.y, z.x);
      dr = pow(r, uPower - 1.0) * uPower * dr + 1.0;
      float zr = pow(r, uPower);
      theta *= uPower; phi *= uPower;
      z = zr * vec3(sin(theta)*cos(phi), sin(theta)*sin(phi), cos(theta));
    } else if (uShape == 1) {
      float rc = max(max(abs(z.x),abs(z.y)),abs(z.z));
      dr = pow(max(rc,1e-5), uPower-1.0)*uPower*dr+1.0;
      z = sign(z)*pow(max(rc,1e-5),uPower);
    } else if (uShape == 2) {
      float rp = max(abs(z.x)+abs(z.y), abs(z.z));
      dr = pow(max(rp,1e-5), uPower-1.0)*uPower*dr+1.0;
      z = sign(z)*pow(max(rp,1e-5),uPower);
    } else {
      float rh = max(length(z.xy)/cos(3.14159/6.0), abs(z.z));
      dr = pow(max(rh,1e-5), uPower-1.0)*uPower*dr+1.0;
      z = sign(z)*pow(max(rh,1e-5),uPower);
    }
    z += pos;
  }
  return 0.5 * log(max(r,1e-5)) * r / max(dr,1e-5);
}

// PERF: tetrahedron-method normal — 4 evaluations instead of 6
vec3 calcNormal(vec3 pos) {
  // Distance-adaptive epsilon: sharper near origin, broader at distance
  float eps = max(uSurfaceEpsilon * 0.5, length(pos - uCamPos) * 5e-4);
  eps = clamp(eps, 5e-5, 5e-3);
  const vec2 k = vec2(1.0, -1.0);
  return normalize(
    k.xyy * mandelbulb(pos + k.xyy*eps) +
    k.yyx * mandelbulb(pos + k.yyx*eps) +
    k.yxy * mandelbulb(pos + k.yxy*eps) +
    k.xxx * mandelbulb(pos + k.xxx*eps)
  );
}

// PERF: skip shadow entirely when outside light is off
// QUALITY: soft penumbra shadow (IQ-style)
float calcShadow(vec3 ro, vec3 rd) {
  if (uUseOutsideLight < 0.5) return 1.0; // skip when unlit
  float t = 0.02;
  float shadow = 1.0;
  float ph = 1e20;
  for (int i = 0; i < 48; i++) {
    float d = mandelbulb(ro + rd * t);
    if (d < uSurfaceEpsilon) return 0.0;
    // Soft shadow: track minimum ratio d/t (Inigo Quilez technique)
    if (uSoftShadow > 0.5) {
      float y = d*d / (2.0*ph);
      float k2 = sqrt(d*d - y*y);
      shadow = min(shadow, 8.0 * k2 / max(t - y, 1e-5));
      ph = d;
    }
    t += d;
    if (t > uMaxDistance * 0.4) break;
  }
  return clamp(shadow, 0.0, 1.0);
}

// Raymarcher with slight step damping to reduce banding artifacts
float rayMarch(vec3 ro, vec3 rd) {
  float t = 0.0;
  for (int i = 0; i < 300; i++) {
    if (i >= uMaxSteps) break;
    float d = mandelbulb(ro + rd * t);
    if (d < uSurfaceEpsilon) return t;
    t += d * 0.92; // slight under-step — reduces missed surfaces at grazing angles
    if (t > uMaxDistance) break;
  }
  return t;
}

// QUALITY: cheap 5-tap ambient occlusion
float calcAO(vec3 pos, vec3 normal) {
  float ao = 0.0;
  float scale = 1.0;
  for (int i = 1; i <= 5; i++) {
    float h = 0.01 + 0.12 * float(i) / 5.0;
    float d = mandelbulb(pos + normal * h);
    ao += (h - d) * scale;
    scale *= 0.85;
  }
  return clamp(1.0 - 6.0 * ao * uAOStrength, 0.0, 1.0);
}

float luma(vec3 c) { return dot(c, vec3(0.299,0.587,0.114)); }

// HSV helpers
vec3 rgb2hsv(vec3 c) {
  float mx = max(max(c.r,c.g),c.b);
  float mn = min(min(c.r,c.g),c.b);
  float d  = mx - mn;
  float h  = 0.0;
  if (d > 1e-5) {
    if      (mx == c.r) h = mod((c.g-c.b)/d, 6.0)/6.0;
    else if (mx == c.g) h = ((c.b-c.r)/d + 2.0)/6.0;
    else                h = ((c.r-c.g)/d + 4.0)/6.0;
  }
  return vec3(h, (mx < 1e-5) ? 0.0 : d/mx, mx);
}
vec3 hsv2rgb(vec3 c) {
  float h = c.x*6.0, s = c.y, v = c.z;
  float i = floor(h), f = h-i;
  float p = v*(1.0-s), q = v*(1.0-s*f), t2 = v*(1.0-s*(1.0-f));
  int ii = int(mod(i,6.0));
  if (ii==0) return vec3(v,t2,p);
  if (ii==1) return vec3(q,v,p);
  if (ii==2) return vec3(p,v,t2);
  if (ii==3) return vec3(p,q,v);
  if (ii==4) return vec3(t2,p,v);
  return vec3(v,p,q);
}

// Hue rotation in HSV space — organic cycling without losing saturation
vec3 hueRotate(vec3 rgb, float amount) {
  vec3 hsv = rgb2hsv(clamp(rgb, 0.0, 1.0));
  hsv.x = fract(hsv.x + amount);
  return hsv2rgb(hsv);
}

vec3 boostPsyColor(vec3 rgb) {
  vec3 hsv = rgb2hsv(clamp(rgb, 0.0, 1.0));
  hsv.y = clamp(hsv.y * 1.6 + 0.18, 0.0, 1.0);
  hsv.z = clamp(hsv.z * 1.15 + 0.05, 0.0, 1.0);
  vec3 boosted = hsv2rgb(hsv);
  float mx = max(max(boosted.r,boosted.g),boosted.b);
  if (mx > 1.0) boosted /= mx;
  return boosted;
}

vec3 applySaturationAndVibrance(vec3 c, float saturation, float vibrance) {
  float lum = luma(c);
  c = mix(vec3(lum), c, saturation);
  float mx = max(max(c.r,c.g),c.b);
  float mn = min(min(c.r,c.g),c.b);
  float sat = mx - mn;
  c = mix(vec3(luma(c)), c, 1.0 + (1.0-sat)*vibrance);
  return c;
}

float quantizeBands(float v) {
  if (uColorBands < 1.5) return v;
  float bands = max(1.0, uColorBands);
  return mix(v, floor(v*bands)/bands, clamp(uBandStrength,0.0,1.0));
}

vec3 psyPalette(float t) {
  t = fract(t);
  if      (t < 0.333333) return mix(uPsyColorA, uPsyColorB, t/0.333333);
  else if (t < 0.666666) return mix(uPsyColorB, uPsyColorC, (t-0.333333)/0.333333);
  else                   return mix(uPsyColorC, uPsyColorD, (t-0.666666)/0.333334);
}

// PSYCHEDELIC: sharper bands — mix sin with a fract sawtooth component
float sharpBand(float v, float sharpness) {
  // sharpness 0=pure sin, 1=fract-saw
  float saw = fract(v * 0.5 + 0.5) * 2.0 - 1.0;
  return mix(sin(v), saw, clamp(sharpness, 0.0, 0.85));
}

float patternValue(vec3 pos, float cyclePhase) {
  float x = pos.x, y = pos.y, z = pos.z;
  float r = length(pos.xy), r3 = length(pos);
  float a = atan(y, x);
  float s = uPatternScale, t = cyclePhase * uPatternSpeed;

  if      (uPatternMode < 0.5)  return 0.0;
  else if (uPatternMode < 1.5)  return 0.5+0.5*sin(y*s+t);
  else if (uPatternMode < 2.5)  return 0.5+0.5*sin(x*s+t);
  else if (uPatternMode < 3.5)  return 0.5+0.5*sin((x+y)*s+t);
  else if (uPatternMode < 4.5)  return 0.5+0.5*sin(y*s+sin(x*s*0.75+t)*2.0+t);
  else if (uPatternMode < 5.5)  return 0.5+0.5*sin(x*s+sin(y*s*0.75+t)*2.0+t);
  else if (uPatternMode < 6.5)  return step(0.0, sin(x*s+t)*sin(y*s+t));
  else if (uPatternMode < 7.5) {
    float wx=x+sin(y*s*0.65+t)*0.6, wy=y+sin(x*s*0.65-t)*0.6;
    return step(0.0, sin(wx*s)*sin(wy*s));
  } else if (uPatternMode < 8.5) {
    float qx=x*0.866025+y*0.5;
    float h1=abs(fract(qx*s)-0.5), h2=abs(fract(y*s)-0.5), h3=abs(fract((qx-y*0.5)*s)-0.5);
    return 1.0-smoothstep(0.18,0.24,min(min(h1,h2),h3));
  } else if (uPatternMode < 9.5)  return 0.5+0.5*sin(r3*s+t);
  else if (uPatternMode < 10.5)  return 0.5+0.5*sin((r3+z*0.4)*s+t);
  else if (uPatternMode < 11.5)  return 0.5+0.5*(sin(x*s+t)*sin(y*s*1.2-t*0.8));
  else if (uPatternMode < 12.5)  return 0.5+0.5*sin(r*s-t);
  else if (uPatternMode < 13.5)  return 0.5+0.5*sin(a*s+t);
  else if (uPatternMode < 14.5)  return 0.5+0.5*sin(r*s+a*3.0-t);
  else if (uPatternMode < 15.5)  return 0.5+0.5*sin(r*s+a*6.0-t);
  else if (uPatternMode < 16.5) {
    vec2 p=pos.xy*s, ip=floor(p), fp=fract(p);
    float md=10.0;
    for (int yy=-1;yy<=1;yy++) for (int xx=-1;xx<=1;xx++) {
      vec2 g=vec2(float(xx),float(yy));
      vec2 o=0.5+0.35*sin(vec2(1.7,2.9)*dot(ip+g,vec2(7.1,5.3))+t);
      vec2 r2=g+o-fp;
      md=min(md,dot(r2,r2));
    }
    return 1.0-smoothstep(0.0,0.4,sqrt(md));
  } else {
    return 0.5+0.5*sin((x+y+z)*s+sin((x-y)*s*0.7+t)*2.0+t);
  }
}

// =====================  MAIN  =====================

void main() {
  // ---- UV + mirror ----
  vec2 baseUv = (gl_FragCoord.xy / iResolution.xy) * 2.0 - 1.0;
  baseUv.x *= iResolution.x / iResolution.y;
  vec2 uv;
  if (uMirrorQuad > 0.5) {
    vec2 uv01 = mod((baseUv+1.0)*1.0, 1.0);
    uv01 = abs(uv01-0.5)*2.0;
    uv = uv01*2.0-1.0;
  } else if (uMirror > 0.5) {
    uv = vec2(abs(baseUv.x), baseUv.y);
  } else {
    uv = baseUv;
  }

  // ---- Chromatic aberration — offset R and B channels slightly ----
  float chromaOff = uChromaStrength * 0.004;
  vec2 uvR = uv + vec2( chromaOff, 0.0);
  vec2 uvB = uv + vec2(-chromaOff, 0.0);

  vec3 ro = uCamPos;
  vec3 rdC = normalize(uv.x  * uCamRight + uv.y  * uCamUp + 1.5 * uCamForward);
  vec3 rdR = normalize(uvR.x * uCamRight + uvR.y * uCamUp + 1.5 * uCamForward);
  vec3 rdB = normalize(uvB.x * uCamRight + uvB.y * uCamUp + 1.5 * uCamForward);

  // March all three rays only when chroma is active; otherwise share tVal
  float tC = rayMarch(ro, rdC);
  float tR = (uChromaStrength > 0.001) ? rayMarch(ro, rdR) : tC;
  float tB = (uChromaStrength > 0.001) ? rayMarch(ro, rdB) : tC;

  // ---- Depth fog / background ----
  float fogC = (tC >= uMaxDistance) ? 1.0 : clamp(tC / (uMaxDistance * 0.55), 0.0, 1.0);
  vec3 bgColor = uFogColor * (0.3 + 0.7 * fogC);

  if (tC >= uMaxDistance) {
    // Background — depth fog colour
    gl_FragColor = vec4(mix(vec3(0.0), uFogColor, uFogStrength * fogC), 1.0);
    return;
  }

  // Helper to compute shaded colour at a hit position / ray direction
  // We run once for the centre ray; R/B channels pick up chromatic split.
  vec3 pos    = ro + rdC * tC;
  vec3 normal = calcNormal(pos);

  vec3 lightDir = normalize(vec3(
    cos(uLightAzimuth)*cos(uLightElevation),
    sin(uLightAzimuth)*cos(uLightElevation),
    sin(uLightElevation)
  ));

  float diffuse  = max(dot(normal, lightDir), 0.0);
  float ambient  = 0.14;
  float shadow   = calcShadow(pos + normal * uSurfaceEpsilon * 2.0, lightDir);
  float ao       = calcAO(pos, normal);

  vec3  viewDir  = normalize(ro - pos);
  vec3  halfDir  = normalize(lightDir + viewDir);
  float specExp  = mix(96.0, 6.0, clamp((uSpecularSize-0.1)/2.9, 0.0, 1.0));
  float spec     = pow(max(dot(normal, halfDir), 0.0), specExp);
  vec3  specular = uLightColor * spec * uSpecularStrength * shadow;

  float lightVal = ambient + (1.0-ambient) * diffuse * shadow;
  lightVal = mix(1.0, lightVal, uShadowStrength);
  lightVal = pow(clamp(lightVal, 0.0, 1.0), max(0.05, uContrast));
  lightVal = clamp(lightVal + lightVal*(1.0-lightVal)*uMidtoneLift, 0.0, 1.0);
  lightVal *= ao; // AO darkens occluded crevices

  float effectiveLightVal = (uUseOutsideLight > 0.5) ? lightVal : 1.0;
  float rim = clamp(1.0 - abs(dot(normal, viewDir)), 0.0, 1.0);

  float cyclePhase   = uPaletteCycle > 0.5 ? iTime * uPaletteCycleSpeed : 0.0;
  float hueRotAmt    = uHueRotateSpeed * iTime * 0.1; // slow organic hue shift
  float pattern      = quantizeBands(patternValue(pos, cyclePhase));
  float activePsyScale = (uPsyScaleCycle > 0.5) ? uEffectivePsyScale : uPsyScale;

  vec3 baseCol;

  if (uPaletteMode < 0.5) {
    baseCol = mix(uShadowTint, uColor, effectiveLightVal);

  } else if (uPaletteMode < 1.5) {
    float rings = quantizeBands(smoothstep(0.18,0.82,
      0.5+0.5*sin(length(pos.xy)*uRingScale + pos.z*1.5 + cyclePhase)));
    vec3 warm    = mix(uShadowTint, uWarmColor, effectiveLightVal);
    vec3 cool    = uCoolColor * pow(rim, 2.0);
    vec3 ringMix = mix(warm, cool, rings * uRingStrength);
    float pd     = pattern * uPatternBlend * uPatternStrength;
    ringMix      = mix(ringMix, mix(uWarmColor,uCoolColor,pattern), pd*0.9);
    baseCol      = mix(uShadowTint, ringMix, clamp(effectiveLightVal+0.18,0.0,1.0));

  } else {
    // ---- PSYCHEDELIC PATH ----
    float radiusField = length(pos.xy) * activePsyScale;
    float angleField  = atan(pos.y,pos.x) * uPsySpinStrength;
    float depthField  = pos.z * 1.3;
    float flowField   = cyclePhase + iTime * uPsyFlow;
    float ridgeField  = rim * 5.0;

    // PSYCHEDELIC: sharpness parameter mixes sin↔saw for harder colour edges
    // We use psyStyle as a proxy: style 2 gets sharpest bands
    float sharpness   = (uPsyStyle > 1.5) ? 0.55 : (uPsyStyle > 0.5 ? 0.30 : 0.10);

    float band1, band2, band3;
    if (uPsyStyle < 0.5) {
      band1 = 0.5+0.5*sharpBand(radiusField*0.8 + angleField*0.75 + flowField*0.7, sharpness);
      band2 = 0.5+0.5*sharpBand((pos.x-pos.y)*activePsyScale*0.45 + depthField*0.7 + flowField*0.5, sharpness);
      band3 = 0.5+0.5*sharpBand(length(pos)*activePsyScale*0.42 - angleField*0.35, sharpness);
    } else if (uPsyStyle < 1.5) {
      band1 = 0.5+0.5*sharpBand(radiusField + angleField + depthField + flowField, sharpness);
      band2 = 0.5+0.5*sharpBand((pos.x-pos.y)*activePsyScale*0.65 - angleField*0.75 + ridgeField + flowField*0.7, sharpness);
      band3 = 0.5+0.5*sharpBand(length(pos)*activePsyScale*0.55 + angleField*1.2 - pos.z*1.2 - flowField*0.45, sharpness);
    } else {
      band1 = 0.5+0.5*sharpBand(radiusField*1.15 + angleField*1.25 + depthField + flowField*1.2, sharpness);
      band2 = 0.5+0.5*sharpBand((pos.x-pos.y)*activePsyScale*0.9 - angleField*1.1 + ridgeField*1.2 + flowField, sharpness);
      band3 = 0.5+0.5*sharpBand(length(pos)*activePsyScale*0.72 + angleField*1.6 - pos.z*1.8 - flowField*0.7, sharpness);
    }
    band1 = quantizeBands(band1);
    band2 = quantizeBands(band2);
    band3 = quantizeBands(band3);

    float pd       = pattern * uPatternBlend * uPatternStrength;
    float paletteT = pow(clamp(fract(band1*0.30 + band2*0.26 + band3*0.20
                       + rim*uPsyMix*0.16 + effectiveLightVal*0.10 + pd*0.55),
                       0.0,1.0), max(0.1, uPaletteContrast));
    paletteT = quantizeBands(paletteT);

    // PSYCHEDELIC: hue rotation applied per-sample before boosting
    vec3 psycho  = hueRotate(boostPsyColor(psyPalette(paletteT)),          hueRotAmt);
    vec3 psycho2 = hueRotate(boostPsyColor(psyPalette(quantizeBands(fract(paletteT+0.22)))), hueRotAmt);
    vec3 psycho3 = hueRotate(boostPsyColor(psyPalette(quantizeBands(fract(paletteT+0.47)))), hueRotAmt);

    vec3 layeredPsy = mix(mix(psycho, psycho2, band2*0.65), psycho3, band3*0.5);

    float rings2   = quantizeBands(0.5+0.5*sin(length(pos.xy)*uRingScale + angleField*0.6 + cyclePhase));
    vec3 warmLift  = mix(vec3(0.0), uWarmColor, rings2*0.24*uRingStrength);
    vec3 ridgeCool = uCoolColor * pow(rim,1.8) * 0.35;

    layeredPsy *= (uUseOutsideLight > 0.5) ? mix(0.7,1.3,lightVal) : 1.15;
    layeredPsy += warmLift + ridgeCool;
    layeredPsy  = mix(layeredPsy, mix(uPsyColorA,uPsyColorD,pattern), pd*0.75);

    float shadowMix = (uUseOutsideLight > 0.5) ? clamp(effectiveLightVal+0.22,0.0,1.0) : 1.0;
    baseCol = mix(uShadowTint, layeredPsy, shadowMix);
  }

  if (uUseOutsideLight > 0.5) {
    float ridge  = pow(rim, 2.2);
    float cavity = pow(1.0-diffuse, 2.0) * (1.0-shadow);
    baseCol += uLightColor * ridge * uRidgeAccent * 0.35;
    baseCol -= vec3(cavity * uCavityStrength * 0.35);
  }

  baseCol = applySaturationAndVibrance(baseCol * uColorIntensity, uColorSaturation, uColorVibrance);

  vec3 shadedColor;
  bool isPsy = (uPaletteMode > 1.5);

  if (isPsy && uPsyShaderMode > 0.5) {
    vec3 psy = max(baseCol, vec3(0.0));
    if (uUseOutsideLight > 0.5)
      psy *= mix(1.0, 0.35+0.65*lightVal, clamp(uPsyDepthShade,0.0,1.0));
    psy = pow(max(psy,vec3(0.0)), vec3(1.0/max(0.001,uPsyContrast)));
    psy = mix(vec3(dot(psy,vec3(0.299,0.587,0.114))), psy, uPsySaturation);

    float brightMask = max(max(psy.r,psy.g),psy.b);
    float glowMask   = smoothstep(uPsyGlowThreshold-0.25, uPsyGlowThreshold, brightMask);
    float rimInward  = 1.0 - pow(clamp(rim*2.5,0.0,1.0), 2.5);
    vec3  psyGlow    = psy * glowMask * rimInward * uPsyInternalGlow * uPsyGlowOn;

    vec3 emissiveCol = psy * uPsyEmission + psyGlow;

    if (uPsyContrastBoost > 0.001)
      emissiveCol = clamp((emissiveCol-0.5)*(1.0+uPsyContrastBoost)+0.5, 0.0, 1.5);

    if (uFractalGlowAccumulation > 0.001) {
      float edgeFactor = pow(clamp(rim,0.0,1.0), 1.2);
      float lc = length(emissiveCol - vec3(dot(emissiveCol,vec3(0.333))));
      emissiveCol += emissiveCol * edgeFactor * lc * uFractalGlowAccumulation;
    }

    float emMax = max(max(emissiveCol.r,emissiveCol.g),emissiveCol.b);
    if (emMax > 1.0) emissiveCol /= emMax;

    if (uPsyShaderMode < 1.5) {
      shadedColor = emissiveCol;
    } else {
      shadedColor = mix(emissiveCol, emissiveCol*mix(0.55,1.0,lightVal), clamp(uPsyDepthShade,0.0,1.0));
    }
    specular = vec3(0.0);

  } else {
    if (uUseOutsideLight > 0.5) {
      if (uPreserveHighlightColor > 0.5) {
        shadedColor = baseCol * mix(vec3(0.25), uLightColor, lightVal);
      } else {
        shadedColor = mix(baseCol*0.35, baseCol, lightVal) + uLightColor*spec*0.25;
      }
    } else {
      shadedColor = baseCol;
      specular    = vec3(0.0);
    }
  }

  // ---- Edge glow ----
  float glowWidthExp = mix(3.5, 0.35, clamp(uGlowWidth/4.0,0.0,1.0));
  float rimPow  = pow(rim, glowWidthExp);
  float glowAA  = fwidth(rimPow)*1.75 + 0.0005;
  float glowMsk = smoothstep(0.02-glowAA,0.02+glowAA,rimPow)*(1.0-smoothstep(0.65-glowAA,0.65+glowAA,rimPow));
  float glowCrd = (uGlowScroll>0.5) ? fract(rim+iTime*uGlowScrollSpeed*mix(1.0,-1.0,step(0.5,uGlowReverse))) : rim;
  vec3  glowLayer = mix(uGlowColorA,uGlowColorB,glowCrd)*glowMsk*mix(uGlowAlphaA,uGlowAlphaB,glowCrd)*uGlowStrength*uGlowOn*(1.0+uGlowEmission);

  // ---- Edge line ----
  float lineWidthExp = mix(7.5,1.2,clamp(uLineWidth/4.0,0.0,1.0));
  float lineRim  = pow(rim, lineWidthExp);
  float lineAA   = fwidth(lineRim)*(0.5+uLineSoftness*2.0)+0.0003;
  float lc       = 0.18;
  float lineMask = clamp((smoothstep(lc-lineAA,lc,lineRim)-smoothstep(lc,lc+lineAA,lineRim))*8.0,0.0,1.0);
  float lineCrd  = (uLineScroll>0.5) ? fract(rim+iTime*uLineScrollSpeed*mix(1.0,-1.0,step(0.5,uLineReverse))) : rim;
  float lineMixAmt = lineMask * mix(uLineAlphaA,uLineAlphaB,lineCrd) * uLineStrength * uLineOn;

  // ---- Inner glow ----
  float innerExp  = mix(6.0,1.0,clamp(uInnerGlowWidth/4.0,0.0,1.0));
  float innerPow  = pow(rim, innerExp);
  float innerAA   = fwidth(innerPow)*2.0+0.0005;
  float innerMask = smoothstep(0.0,innerAA+1e-4,innerPow)*(1.0-smoothstep(0.82-innerAA,0.82+innerAA,innerPow));
  vec3  innerGlow = uInnerGlowColor * innerMask * uInnerGlowStrength;

  vec3 col = shadedColor + specular + glowLayer + innerGlow;
  col = mix(col, mix(uLineColorA,uLineColorB,lineCrd), clamp(lineMixAmt,0.0,1.0));

  // ---- Chromatic aberration — re-evaluate R and B channels ----
  if (uChromaStrength > 0.001) {
    // For R channel: use rdR hit position colour's red component
    if (tR < uMaxDistance) {
      vec3 posR   = ro + rdR * tR;
      vec3 normR  = calcNormal(posR);
      float rimR  = clamp(1.0 - abs(dot(normR, normalize(ro-posR))), 0.0, 1.0);
      // Approximate: shift hue slightly and take red channel
      float redShift = hueRotate(col, 0.02).r * (0.5 + rimR*0.5);
      col.r = mix(col.r, redShift, uChromaStrength * 0.7);
    }
    if (tB < uMaxDistance) {
      vec3 posB   = ro + rdB * tB;
      vec3 normB  = calcNormal(posB);
      float rimB  = clamp(1.0 - abs(dot(normB, normalize(ro-posB))), 0.0, 1.0);
      float blueShift = hueRotate(col, -0.02).b * (0.5 + rimB*0.5);
      col.b = mix(col.b, blueShift, uChromaStrength * 0.7);
    }
  }

  // ---- Depth fog blend ----
  float depthFog = clamp(tC / (uMaxDistance * 0.5), 0.0, 1.0) * uFogStrength;
  col = mix(col, uFogColor, depthFog * depthFog);

  col *= uLightIntensity;
  gl_FragColor = vec4(clamp(col, 0.0, 1.0), 1.0);
}
