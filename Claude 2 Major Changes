  function getMimeTypeFromFormat(f) {
    const try1=(t)=>MediaRecorder.isTypeSupported(t)?t:null;
    if(f==="webm-vp9") return try1("video/webm;codecs=vp9")||try1("video/webm")||"";
    if(f==="webm")     return try1("video/webm")||"";
    if(f==="mp4")      return try1("video/mp4;codecs=avc1")||try1("video/mp4")||"";
