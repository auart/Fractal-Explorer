    glowFolder.add(params,"glowWidth",0.15,4).name("Glow Width");
    glowFolder.add(params,"glowEmission",0,3).name("Glow Emission");
    glowFolder.add(params,"glowScroll").name("Glow Scroll");
    glowFolder.add(params,"glowScrollSpeed",0,3).name("Glow Scroll Speed");
    glowFolder.add(params,"glowReverse").name("Glow Reverse");

    const lineFolder = gui.addFolder("Edge Line");
    lineFolder.add(params,"lineOn").name("Line On");
    lineFolder.addColor(params,"lineColorA").name("Line Color A");
    lineFolder.add(params,"lineAlphaA",0,1).name("Line Alpha A");
    lineFolder.addColor(params,"lineColorB").name("Line Color B");
    lineFolder.add(params,"lineAlphaB",0,1).name("Line Alpha B");
    lineFolder.add(params,"lineStrength",0,2).name("Line Strength");
    lineFolder.add(params,"lineWidth",0.1,4).name("Line Width");
    lineFolder.add(params,"lineSoftness",0,1).name("Line Softness");
    lineFolder.add(params,"lineScroll").name("Line Scroll");
    lineFolder.add(params,"lineScrollSpeed",0,3).name("Line Scroll Speed");
    lineFolder.add(params,"lineReverse").name("Line Reverse");

    const innerGlowFolder = gui.addFolder("Inner Glow");
    innerGlowFolder.add(params,"innerGlowStrength",0,2).name("Inner Glow Strength");
    innerGlowFolder.add(params,"innerGlowWidth",0.1,4).name("Inner Glow Width");
    innerGlowFolder.addColor(params,"innerGlowColor").name("Inner Glow Color");

    const audioFolder = gui.addFolder("Audio Settings");
    audioFolder.add(params,"musicReact").name("Mic Reactive");
    audioFolder.add(params,"micSensitivity",0,5).name("Mic Sensitivity");
    audioFolder.add(params,"musicMatch").name("Music Match");

    const miscFolder = gui.addFolder("Misc");
    miscFolder.add(params,"zoomValue",0,4).name("Zoom");
    rotXController = miscFolder.add(params,"uFractalRotationX",0,Math.PI*2).name("Rotation X");
    rotYController = miscFolder.add(params,"uFractalRotationY",0,Math.PI*2).name("Rotation Y");
    rotZController = miscFolder.add(params,"uFractalRotationZ",0,Math.PI*2).name("Rotation Z");
    miscFolder.add(params,"mirror").name("Mirror Mode");
    miscFolder.add(params,"mirrorQuad").name("Quad Mirror Mode");

    fractalFolder.open(); colorFolder.open(); psyShaderFolder.open();
    gradingFolder.open(); patternFolder.open(); lightingFolder.open();
    fogFolder.close(); glowFolder.close(); lineFolder.close();
    innerGlowFolder.close(); audioFolder.close(); miscFolder.close();

    window.addEventListener("resize", () => { layoutPreviewFrame(); resizeRendererToPreviewFrame(); });
    renderer.domElement.addEventListener("mousedown", onMouseDown);
    renderer.domElement.addEventListener("mouseup",   onMouseUp);
    renderer.domElement.addEventListener("mousemove", onMouseMove);
    renderer.domElement.addEventListener("touchstart", onTouchStart, {passive:false});
    renderer.domElement.addEventListener("touchmove",  onTouchMove,  {passive:false});
    renderer.domElement.addEventListener("touchend",   onTouchEnd);

    clock = new THREE.Clock();
  }

  function setU(name, value) { material.uniforms[name].value = value; }
  function setUC(name, value) { material.uniforms[name].value.set(value); }
  function setUB(name, bool) { material.uniforms[name].value = bool ? 1.0 : 0.0; }

  function animate() {
    requestAnimationFrame(animate);

    // FPS
    fpsFrames++;
    const now = performance.now();
    if (now - fpsLast >= 500) {
      fpsDisplay = Math.round(fpsFrames * 1000 / (now - fpsLast));
      fpsEl.textContent = `${fpsDisplay} fps`;
      fpsFrames = 0; fpsLast = now;
    }

    const dt = clock.getDelta();
    const t  = clock.elapsedTime;

    setU("iTime", t);
    navCamera.position.z = params.zoomValue;

    // Audio
    let sensitiveAvg = 0;
    if (params.musicReact && micEnabled) {
      analyser.getByteFrequencyData(dataArray);
      let sum=0; for(let i=0;i<bufferLength;i++) sum+=dataArray[i];
      sensitiveAvg = (sum/bufferLength/255.0) * params.micSensitivity;
    }

    // Trippy mode
    if (params.trippyMode) {
      setUC("uColor", new THREE.Color().setHSL((t*params.trippySpeed/10)%1, 0.7, 0.5));
    } else { setUC("uColor", params.uColor); }

    // Kaleidoscope
    if (params.kaleidoscopeMode) {
      params.lightAzimuth = ((params.lightAzimuth + dt*params.kaleidoscopeSpeed + Math.PI) % (Math.PI*2)) - Math.PI;
      if (lightAzimuthController) lightAzimuthController.updateDisplay();
    }

    // Power animation
    if (params.powerAnimation) {
      let speed = params.powerAnimationSpeed;
      if (params.musicMatch && micEnabled) {
        if (sensitiveAvg>0.4 && t-lastBeatTime>0.3) { bpm=60/(t-lastBeatTime); lastBeatTime=t; }
        speed *= bpm/120;
      }
      const range = params.powerMax - params.powerMin;
      if (range<=0.0001) { setU("uPower",params.powerMin); }
      else {
        const x=(t*speed)%(2*range);
        setU("uPower", params.powerMin + (x<range ? x : 2*range-x));
      }
    } else { setU("uPower", params.uPower); }

    // Auto rotate
    if (!isDragging) {
      if (params.autoRotateX) params.uFractalRotationX += dt*params.rotateSpeedX;
      if (params.autoRotateY) params.uFractalRotationY += dt*params.rotateSpeedY;
      if (params.autoRotateZ) params.uFractalRotationZ += dt*params.rotateSpeedZ;
      if (rotXController) rotXController.updateDisplay();
      if (rotYController) rotYController.updateDisplay();
      if (rotZController) rotZController.updateDisplay();
    }

    // Psy scale cycle
    let effectivePsyScale = params.psyScale;
    if (params.psyScaleCycle) {
      effectivePsyScale = Math.max(0.1, params.psyScale + Math.sin(t*params.psyScaleCycleSpeed)*params.psyScale*0.5);
    }
    setU("uEffectivePsyScale", effectivePsyScale);
    setU("uMusic", (params.musicReact && micEnabled) ? sensitiveAvg : 0);

    material.uniforms.uFractalRotation.value.set(params.uFractalRotationX, params.uFractalRotationY, params.uFractalRotationZ);

    // All uniform updates
    setU("uBailout",      params.uBailout);
    setU("uIterations",   params.uIterations);
    setU("uSurfaceEpsilon",params.uSurfaceEpsilon);
    setU("uMaxSteps",     params.uMaxSteps);
    setU("uMaxDistance",  params.uMaxDistance);
    setU("uShape",        params.uShape);
    setUB("uMirror",      params.mirror);
    setUB("uMirrorQuad",  params.mirrorQuad);

    setU("uLightIntensity",    params.lightIntensity);
    setU("uLightAzimuth",      params.lightAzimuth);
    setU("uLightElevation",    params.lightElevation);
    setUC("uLightColor",       params.lightColor);
    setU("uShadowStrength",    params.shadowStrength);
    setUC("uShadowTint",       params.shadowTint);
    setU("uContrast",          params.contrast);
    setU("uMidtoneLift",       params.midtoneLift);
    setU("uSpecularStrength",  params.specularStrength);
    setU("uSpecularSize",      params.specularSize);

    setU("uColorSaturation",        params.colorSaturation);
    setU("uColorVibrance",          params.colorVibrance);
    setU("uPaletteContrast",        params.paletteContrast);
    setU("uColorIntensity",         params.colorIntensity);
    setUB("uPreserveHighlightColor",params.preserveHighlightColor);
    setU("uRidgeAccent",            params.ridgeAccent);
    setU("uCavityStrength",         params.cavityStrength);

    setUB("uGlowOn",        params.glowOn);
    setUC("uGlowColorA",    params.glowColorA);
    setU("uGlowAlphaA",     params.glowAlphaA);
    setUC("uGlowColorB",    params.glowColorB);
    setU("uGlowAlphaB",     params.glowAlphaB);
    setU("uGlowStrength",   params.glowStrength);
    setU("uGlowWidth",      params.glowWidth);
    setU("uGlowEmission",   params.glowEmission);
    setUB("uGlowScroll",    params.glowScroll);
    setU("uGlowScrollSpeed",params.glowScrollSpeed);
    setUB("uGlowReverse",   params.glowReverse);

    setUB("uLineOn",        params.lineOn);
    setUC("uLineColorA",    params.lineColorA);
    setU("uLineAlphaA",     params.lineAlphaA);
    setUC("uLineColorB",    params.lineColorB);
    setU("uLineAlphaB",     params.lineAlphaB);
    setU("uLineStrength",   params.lineStrength);
    setU("uLineWidth",      params.lineWidth);
    setU("uLineSoftness",   params.lineSoftness);
    setUB("uLineScroll",    params.lineScroll);
    setU("uLineScrollSpeed",params.lineScrollSpeed);
    setUB("uLineReverse",   params.lineReverse);

    setU("uInnerGlowStrength", params.innerGlowStrength);
    setU("uInnerGlowWidth",    params.innerGlowWidth);
    setUC("uInnerGlowColor",   params.innerGlowColor);

    setU("uPaletteMode",       params.paletteMode);
    setU("uRingScale",         params.ringScale);
    setU("uRingStrength",      params.ringStrength);
    setUC("uWarmColor",        params.warmColor);
    setUC("uCoolColor",        params.coolColor);
    setUC("uPsyColorA",        params.psyColorA);
    setUC("uPsyColorB",        params.psyColorB);
    setUC("uPsyColorC",        params.psyColorC);
    setUC("uPsyColorD",        params.psyColorD);
    setU("uPsyMix",            params.psyMix);
    setU("uPsyScale",          params.psyScale);
    setU("uPsyFlow",           params.psyFlow);
    setU("uPsySpinStrength",   params.psySpinStrength);
    setUB("uPaletteCycle",     params.paletteCycle);
    setU("uPaletteCycleSpeed", params.paletteCycleSpeed);
    setU("uPsyStyle",          params.psyStyle);

    setU("uPatternMode",     params.patternMode);
    setU("uPatternStrength", params.patternStrength);
    setU("uPatternScale",    params.patternScale);
    setU("uPatternSpeed",    params.patternSpeed);
    setU("uPatternBlend",    params.patternBlend);

    setU("uColorBands",   params.colorBands);
    setU("uBandStrength", params.bandStrength);

    setU("uPsyShaderMode",        params.psyShaderMode);
    setU("uPsyEmission",          params.psyEmission);
    setU("uPsyDepthShade",        params.psyDepthShade);
    setU("uPsyContrast",          params.psyContrast);
    setU("uPsySaturation",        params.psySaturation);
    setU("uPsyInternalGlow",      params.psyInternalGlow);
    setU("uPsyGlowThreshold",     params.psyGlowThreshold);
    setUB("uPsyGlowOn",           params.psyGlowOn);

    setUB("uUseOutsideLight",          params.useOutsideLight);
    setU("uFractalGlowAccumulation",   params.fractalGlowAccumulation);
    setU("uPsyContrastBoost",          params.psyContrastBoost);
    setUB("uPsyScaleCycle",            params.psyScaleCycle);
    setU("uPsyScaleCycleSpeed",        params.psyScaleCycleSpeed);

    // v3 uniforms
    setU("uFogStrength",    params.fogStrength);
    setUC("uFogColor",      params.fogColor);
    setU("uAOStrength",     params.aoStrength);
    setUB("uSoftShadow",    params.softShadow);
    setU("uHueRotateSpeed", params.hueRotateSpeed);
    setU("uChromaStrength", params.chromaStrength);

    // Camera
    material.uniforms.uCamPos.value.copy(navCamera.position);
    material.uniforms.uCamForward.value.copy(new THREE.Vector3(0,0,-1).applyQuaternion(navCamera.quaternion).normalize());
    material.uniforms.uCamRight.value.copy(new THREE.Vector3(1,0,0).applyQuaternion(navCamera.quaternion).normalize());
    material.uniforms.uCamUp.value.copy(new THREE.Vector3(0,1,0).applyQuaternion(navCamera.quaternion).normalize());

    // Keyboard fly
    if (keys["ArrowUp"]||keys["w"])   navCamera.translateZ(-params.flySpeed);
    if (keys["ArrowDown"]||keys["s"]) navCamera.translateZ( params.flySpeed);
    if (keys["ArrowLeft"]||keys["a"]) navCamera.translateX(-params.flySpeed);
    if (keys["ArrowRight"]||keys["d"])navCamera.translateX( params.flySpeed);
    if (keys["q"]) navCamera.translateY( params.flySpeed);
    if (keys["e"]) navCamera.translateY(-params.flySpeed);

    renderer.render(scene, orthoCamera);
  }

  refreshPresetSelect();
  init();
  animate();
</script>
</body>
</html>
