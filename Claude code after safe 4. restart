    function getCurrentPresetData() {
      const data = {};
      PRESET_KEYS.forEach((key) => { data[key] = params[key]; });
      return data;
    }

    function applyPresetData(data) {
      PRESET_KEYS.forEach((key) => {
        if (Object.prototype.hasOwnProperty.call(data, key)) params[key] = data[key];
      });
      refreshGuiDisplays();
    }

    function refreshGuiDisplays() {
      if (gui && gui.__controllers) gui.__controllers.forEach((c) => c.updateDisplay());
      if (gui && gui.__folders) {
        Object.values(gui.__folders).forEach((folder) => {
          folder.__controllers.forEach((c) => c.updateDisplay());
        });
      }
      if (rotXController) rotXController.updateDisplay();
      if (rotYController) rotYController.updateDisplay();
      if (rotZController) rotZController.updateDisplay();
      if (lightAzimuthController) lightAzimuthController.updateDisplay();
      if (lightElevationController) lightElevationController.updateDisplay();
    }

    function loadPresetsFromStorage() {
      try {
        const raw = localStorage.getItem(PRESET_STORAGE_KEY);
        if (!raw) return {};
        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === "object" ? parsed : {};
      } catch (err) {
        console.error("Failed to read presets:", err);
        return {};
      }
    }

    function savePresetsToStorage(presets) {
      localStorage.setItem(PRESET_STORAGE_KEY, JSON.stringify(presets));
    }

    function refreshPresetSelect() {
      const presets = loadPresetsFromStorage();
      const names = Object.keys(presets).sort((a, b) => a.localeCompare(b));

      presetSelect.innerHTML = "";
      if (names.length === 0) {
        const opt = document.createElement("option");
        opt.value = "";
        opt.textContent = "No saved presets";
        presetSelect.appendChild(opt);
        return;
      }

      names.forEach((name) => {
        const opt = document.createElement("option");
        opt.value = name;
        opt.textContent = name;
        presetSelect.appendChild(opt);
      });
    }

    function savePresetByName(name, overwrite = false) {
      const trimmed = name.trim();
      if (!trimmed) {
        alert("Enter a preset name first.");
        return;
      }

      const presets = loadPresetsFromStorage();
      if (!overwrite && presets[trimmed]) {
        alert("A preset with that name already exists. Use Overwrite Selected or a new name.");
        return;
      }

      presets[trimmed] = {
        name: trimmed,
        savedAt: new Date().toISOString(),
        values: getCurrentPresetData()
      };

      savePresetsToStorage(presets);
      refreshPresetSelect();
      presetSelect.value = trimmed;
    }

    function loadSelectedPreset() {
      const selected = presetSelect.value;
      if (!selected) {
        alert("Select a preset first.");
        return;
      }

      const presets = loadPresetsFromStorage();
      if (!presets[selected]) {
        alert("Preset not found.");
        refreshPresetSelect();
        return;
      }

      applyPresetData(presets[selected].values);
      presetNameInput.value = selected;
    }

    function deleteSelectedPreset() {
      const selected = presetSelect.value;
      if (!selected) {
        alert("Select a preset first.");
        return;
      }

      const presets = loadPresetsFromStorage();
      if (!presets[selected]) return;

      delete presets[selected];
      savePresetsToStorage(presets);
      refreshPresetSelect();
      presetNameInput.value = "";
    }

    function exportSelectedPreset() {
      const selected = presetSelect.value || presetNameInput.value.trim();
      if (!selected) {
        alert("Select or enter a preset name first.");
        return;
      }

      const presets = loadPresetsFromStorage();
      const preset = presets[selected];
      if (!preset) {
        alert("Save the preset first before exporting it.");
        return;
      }

      const blob = new Blob([JSON.stringify(preset, null, 2)], { type: "application/json" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = `${selected}.json`;
      link.click();
      URL.revokeObjectURL(url);
    }

    function importPresetFromObject(obj) {
      if (!obj || typeof obj !== "object" || !obj.values) {
        alert("Invalid preset file.");
        return;
      }

      const baseName = obj.name && typeof obj.name === "string" ? obj.name.trim() : "Imported Preset";
      let finalName = baseName || "Imported Preset";

      const presets = loadPresetsFromStorage();
      if (presets[finalName]) {
        let i = 2;
        while (presets[`${finalName} ${i}`]) i++;
        finalName = `${finalName} ${i}`;
      }

      presets[finalName] = {
        name: finalName,
        savedAt: new Date().toISOString(),
        values: obj.values
      };

      savePresetsToStorage(presets);
      refreshPresetSelect();
      presetSelect.value = finalName;
      presetNameInput.value = finalName;
    }

